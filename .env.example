# Firebase web config — copy to .env and fill from Firebase Console → Project Settings → General → Your apps (Web).
# For Vercel deployment, add these same keys in Project Settings → Environment Variables.
# All keys are PUBLIC_* because they are client-side (Firebase web config is meant to be public;
# security is enforced by Firestore rules + Firebase Auth, not by hiding the API key).

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
