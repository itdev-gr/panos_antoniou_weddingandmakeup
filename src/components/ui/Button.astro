---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'outline-light';
  href?: string;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { variant = 'primary', href, size = 'md', class: className = '' } = Astro.props;

const sizeClasses = {
  sm: 'px-5 py-2 text-[10px]',
  md: 'px-7 py-3 text-xs',
  lg: 'px-9 py-4 text-xs',
};

const variantClasses = {
  primary: 'bg-accent text-cream hover:bg-brown border border-accent hover:border-brown',
  secondary: 'bg-cream text-brown hover:bg-sand border border-cream',
  outline: 'bg-transparent text-accent border border-accent hover:bg-accent hover:text-cream',
  'outline-light': 'bg-transparent text-cream border border-cream/40 hover:bg-cream hover:text-brown',
};

const baseClasses = `inline-flex items-center justify-center font-sans font-medium tracking-widest-plus uppercase rounded-sm transition-all duration-300 ${sizeClasses[size]} ${variantClasses[variant]} ${className}`;
---

{href ? (
  <a href={href} class={baseClasses}>
    <slot />
  </a>
) : (
  <button class={baseClasses}>
    <slot />
  </button>
)}
