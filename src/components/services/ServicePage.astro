---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import Button from '../ui/Button.astro';
import CTABanner from '../home/CTABanner.astro';
import { locations } from '../../data/services';

interface Props {
  title: string;
  metaTitle: string;
  metaDescription: string;
  heroImage: string;
  intro: string;
  description: string;
  features: { title: string; text: string }[];
  quote?: string;
}

const { title, metaTitle, metaDescription, heroImage, intro, description, features, quote } = Astro.props;
---

<PageLayout title={metaTitle} description={metaDescription}>
  <!-- Service Hero -->
  <section class="relative pt-24 pb-0 lg:pt-0 lg:pb-0">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[60vh]">
      <div class="relative aspect-[4/3] lg:aspect-auto overflow-hidden">
        <img src={heroImage} alt={title} class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-r from-transparent to-brown-dark/20 hidden lg:block"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-brown-dark/30 via-transparent to-transparent lg:hidden"></div>
      </div>
      <div class="flex items-center bg-sand p-8 lg:p-16 xl:p-20">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <div class="w-8 h-px bg-gold-muted"></div>
            <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-accent-light">Services</p>
          </div>
          <h1 class="text-display-sm md:text-display font-serif italic text-brown-dark mb-6">{title}</h1>
          <div class="w-12 h-px bg-gold-muted mb-6"></div>
          <p class="text-base text-accent-light leading-relaxed mb-8">{intro}</p>
          <Button variant="primary" href="/contact">Book a Consultation</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Description -->
  <section class="relative section-padding bg-cream">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-muted/40 to-transparent"></div>

    <div class="container-content max-w-narrow">
      <p class="text-lg text-brown/80 leading-relaxed text-center" data-reveal>{description}</p>

      {quote && (
        <blockquote class="mt-12 text-center" data-reveal>
          <div class="text-4xl font-serif text-gold-muted leading-none mb-3">&ldquo;</div>
          <p class="text-xl font-serif italic text-brown-dark leading-relaxed">{quote}</p>
        </blockquote>
      )}
    </div>
  </section>

  <!-- Features -->
  <section class="relative section-padding bg-sand/50">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-muted/40 to-transparent"></div>

    <div class="container-content">
      <SectionHeading eyebrow="What's Included" title="Service Details" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 max-w-4xl mx-auto">
        {features.map((feature, i) => (
          <div class="flex gap-5" data-reveal style={`transition-delay: ${i * 100}ms`}>
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center mt-1">
              <span class="text-sm font-sans font-semibold text-accent">{String(i + 1).padStart(2, '0')}</span>
            </div>
            <div>
              <h3 class="text-lg font-serif italic text-brown-dark mb-2">{feature.title}</h3>
              <p class="text-sm text-accent-light leading-relaxed">{feature.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reassurance Strip -->
  <section class="bg-sand/50 border-t border-sand-dark/50">
    <div class="container-content px-6 lg:px-12 py-12 lg:py-16">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 lg:gap-12 text-center">
        <div data-reveal>
          <div class="w-10 h-10 rounded-full bg-cream border border-sand-dark flex items-center justify-center mx-auto mb-4">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
          </div>
          <p class="text-sm font-serif italic text-brown-dark mb-1">Consultation Included</p>
          <p class="text-xs text-accent-light/60">Personalized to your vision</p>
        </div>
        <div data-reveal style="transition-delay: 100ms">
          <div class="w-10 h-10 rounded-full bg-cream border border-sand-dark flex items-center justify-center mx-auto mb-4">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
            </svg>
          </div>
          <p class="text-sm font-serif italic text-brown-dark mb-1">Premium Products</p>
          <p class="text-xs text-accent-light/60">Industry-leading brands</p>
        </div>
        <div data-reveal style="transition-delay: 200ms">
          <div class="w-10 h-10 rounded-full bg-cream border border-sand-dark flex items-center justify-center mx-auto mb-4">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <p class="text-sm font-serif italic text-brown-dark mb-1">Travel Worldwide</p>
          <p class="text-xs text-accent-light/60">Available for destination weddings</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Locations -->
  <section class="py-12 bg-cream">
    <div class="container-content text-center">
      <p class="text-xs font-sans font-medium tracking-ultra-wide uppercase text-accent-light mb-3">Available In</p>
      <p class="text-sm text-brown/60 tracking-wider">{locations.join(' \u00B7 ')}</p>
    </div>
  </section>

  <CTABanner />
</PageLayout>
