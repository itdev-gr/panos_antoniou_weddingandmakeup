---
import CTABanner from '../home/CTABanner.astro';
import enDict from '../../i18n/en/bridal-lounge';
import elDict from '../../i18n/el/bridal-lounge';
import { isLocale, useTranslations, getEntry, localizedPath, type Locale } from '../../i18n/utils';

const lang: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'en';
const dict = { en: enDict, el: elDict };
const t = useTranslations(dict, lang);

const serviceItems = getEntry<{ id: string; name: string; price: string }[]>(dict, lang, 'services.items');
---

<!-- Hero -->
<section class="relative min-h-[75vh] lg:min-h-[85vh] flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="/images/bridal-lounge/bridesmaids-getting-ready.jpg"
      alt="Bridal Lounge Santorini"
      class="w-full h-full object-cover object-top"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-near-black/90 via-near-black/80 to-charcoal/90"></div>
  </div>
  <div class="container-content px-6 lg:px-12 text-center relative z-10">
    <h1 class="text-display-sm md:text-display lg:text-display-lg font-serif italic text-white leading-tight mb-6" data-reveal>
      {t('hero.title')}
    </h1>
    <p class="text-sm md:text-base font-sans tracking-widest-plus uppercase text-white/60" data-reveal>
      {t('hero.eyebrow')}
    </p>
  </div>
</section>

<!-- The Concept -->
<section class="bg-white py-20 lg:py-28 px-6 lg:px-12">
  <div class="container-content max-w-narrow mx-auto text-center" data-reveal>
    <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-6">
      {t('concept.eyebrow')}
    </p>
    <div class="flex items-center justify-center gap-3 mb-10">
      <div class="w-10 h-px bg-gold"></div>
      <div class="w-1.5 h-1.5 rounded-full bg-gold"></div>
      <div class="w-10 h-px bg-gold"></div>
    </div>
    <p class="text-base md:text-lg font-serif text-grey leading-relaxed">
      {t('concept.body')}
    </p>
  </div>
</section>

<!-- The Space: Volcanic Soul -->
<section class="relative bg-near-black py-24 lg:py-32 px-6 lg:px-12 overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="/images/bridal-lounge/bride-preparation.jpg"
      alt="Volcanic-inspired bridal studio"
      class="w-full h-full object-cover opacity-20" style="object-position: center 25%;"
    />
  </div>
  <div class="container-content relative z-10">
    <div class="max-w-narrow mx-auto text-center mb-16" data-reveal>
      <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-6">
        {t('space.eyebrow')}
      </p>
      <h2 class="text-display-sm md:text-display font-serif italic text-white mb-8">
        {t('space.title')}
      </h2>
      <div class="flex items-center justify-center gap-3 mb-10">
        <div class="w-10 h-px bg-gold"></div>
        <div class="w-1.5 h-1.5 rounded-full bg-gold"></div>
        <div class="w-10 h-px bg-gold"></div>
      </div>
      <p class="text-base md:text-lg font-serif text-white/70 leading-relaxed">
        {t('space.body')}
      </p>
    </div>

    <!-- Features -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 max-w-5xl mx-auto">
      <div class="text-center border border-white/10 p-8 lg:p-10" data-reveal>
        <div class="w-12 h-px bg-gold mx-auto mb-6"></div>
        <h3 class="text-lg font-serif italic text-white mb-4">{t('features.driftwood.title')}</h3>
        <p class="text-sm font-sans text-white/60 leading-relaxed">
          {t('features.driftwood.body')}
        </p>
      </div>
      <div class="text-center border border-white/10 p-8 lg:p-10" data-reveal style="transition-delay: 100ms">
        <div class="w-12 h-px bg-gold mx-auto mb-6"></div>
        <h3 class="text-lg font-serif italic text-white mb-4">{t('features.whiteGold.title')}</h3>
        <p class="text-sm font-sans text-white/60 leading-relaxed">
          {t('features.whiteGold.body')}
        </p>
      </div>
      <div class="text-center border border-white/10 p-8 lg:p-10" data-reveal style="transition-delay: 200ms">
        <div class="w-12 h-px bg-gold mx-auto mb-6"></div>
        <h3 class="text-lg font-serif italic text-white mb-4">{t('features.lighting.title')}</h3>
        <p class="text-sm font-sans text-white/60 leading-relaxed">
          {t('features.lighting.body')}
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Bridal Boudoir & Editorial Sessions -->
<section class="bg-off-white py-20 lg:py-28 px-6 lg:px-12">
  <div class="container-content">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Image -->
      <div class="relative" data-reveal>
        <img
          src="/images/bridal-lounge/bride-preparation.jpg"
          alt="Bridal boudoir editorial session"
          class="w-full aspect-[4/5] object-cover"
        />
        <div class="absolute inset-0 bg-charcoal/10"></div>
      </div>

      <!-- Text -->
      <div data-reveal style="transition-delay: 150ms">
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-6">
          {t('boudoir.eyebrow')}
        </p>
        <h2 class="text-display-sm md:text-display font-serif italic text-charcoal mb-6">
          {t('boudoir.title')}
        </h2>
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-px bg-gold"></div>
          <div class="w-1.5 h-1.5 rounded-full bg-gold"></div>
          <div class="w-10 h-px bg-gold"></div>
        </div>
        <p class="text-base md:text-lg font-serif text-grey leading-relaxed">
          {t('boudoir.body')}
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Studio Services -->
<section class="bg-white py-20 lg:py-28 px-6 lg:px-12">
  <div class="container-content max-w-narrow mx-auto">
    <div class="text-center mb-14" data-reveal>
      <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
        {t('services.eyebrow')}
      </p>
      <h2 class="text-display-sm md:text-display font-serif italic text-charcoal">
        {t('services.heading')}
      </h2>
    </div>

    <div class="space-y-0" data-reveal>
      {serviceItems.map((service, i) => (
        <div class="flex items-center justify-between py-5 border-b border-gold/20" style={`transition-delay: ${i * 80}ms`}>
          <span class="text-base md:text-lg font-serif text-charcoal">{service.name}</span>
          <span class="text-sm font-sans font-medium text-gold ml-4 whitespace-nowrap">{service.price}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<CTABanner
  title={t('cta.title')}
  buttonText={t('cta.buttonText')}
  buttonHref={localizedPath('/contact', lang)}
/>
