---
import enDict from '../../i18n/en/blog';
import elDict from '../../i18n/el/blog';
import { isLocale, useTranslations, getEntry, type Locale } from '../../i18n/utils';

const lang: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'en';
const dict = { en: enDict, el: elDict };
const t = useTranslations(dict, lang);

type Post = {
  title: string;
  slug: string;
  excerpt: string;
  date: string;
  image: string;
  category: string;
  alt: string;
};

const postsObj = getEntry<Record<string, Post>>(dict, lang, 'index.posts');
const posts: Post[] = [
  postsObj.santoriniDreamWedding,
  postsObj.weddingBeautician,
  postsObj.bestWeddingMakeupServices,
];
---

<!-- Cinematic Hero -->
<section class="relative min-h-[40vh] lg:min-h-[50vh] overflow-hidden">
  <div class="absolute inset-0">
    <img src="/images/scenery/oia-blue-domes.jpg" alt="" class="w-full h-full object-cover object-center" />
    <div class="absolute inset-0 bg-gradient-to-b from-near-black/30 via-near-black/50 to-near-black/80"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-near-black/60 via-transparent to-transparent"></div>
  </div>

  <div class="relative z-10 container-content px-6 lg:px-12 flex items-end pb-16 lg:pb-20 min-h-[40vh] lg:min-h-[50vh]">
    <div class="max-w-xl">
      <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-white/50 mb-4" data-reveal>
        {t('index.hero.eyebrow')}
      </p>
      <h1 class="text-display-sm md:text-display lg:text-display-lg font-serif italic text-white leading-tight mb-4" data-reveal>
        {t('index.hero.title')}
      </h1>
      <div class="w-12 h-px bg-gold/60 mb-5" data-reveal></div>
      <p class="text-base text-white/60 leading-relaxed max-w-md" data-reveal>
        {t('index.hero.subtitle')}
      </p>
    </div>
  </div>
</section>

<!-- Posts -->
<section class="relative section-padding bg-white">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>

  <div class="container-content">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {posts.map((post, i) => (
        <a
          href={post.slug}
          class="group block"
          data-reveal
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class="aspect-[4/3] overflow-hidden rounded-sm mb-5">
            <img src={post.image} alt={post.alt} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-[10px] font-sans font-medium tracking-widest uppercase text-forest-green bg-off-white px-3 py-1 rounded-full">
              {post.category}
            </span>
            <span class="text-xs text-grey/60">{post.date}</span>
          </div>
          <h3 class="text-lg font-serif italic text-charcoal mb-2 group-hover:text-forest-green transition-colors duration-300">
            {post.title}
          </h3>
          <p class="text-sm text-grey leading-relaxed">
            {post.excerpt}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
