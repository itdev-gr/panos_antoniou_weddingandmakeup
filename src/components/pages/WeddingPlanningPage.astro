---
import CTABanner from '../home/CTABanner.astro';
import enDict from '../../i18n/en/wedding-planning';
import elDict from '../../i18n/el/wedding-planning';
import { isLocale, useTranslations, getEntry, localizedPath, type Locale } from '../../i18n/utils';

const lang: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'en';
const dict = { en: enDict, el: elDict };
const t = useTranslations(dict, lang);

type Tier = {
  name: string;
  price: string;
  startingFrom?: boolean;
  includes: string[];
};

const fullPlanningTiers = getEntry<Tier[]>(dict, lang, 'fullPlanning.tiers');
const elopementTiers = getEntry<Tier[]>(dict, lang, 'elopements.tiers');
const proposalTiers = getEntry<Tier[]>(dict, lang, 'proposals.tiers');
const sailingTiers = getEntry<Tier[]>(dict, lang, 'sailing.tiers');

const advantageItems = getEntry<{ title: string; body: string }[]>(dict, lang, 'advantage.items');

const startingFromLabel = t('fullPlanning.startingFromLabel');
const contactHref = localizedPath('/contact', lang);
---

<!-- Hero -->
<section class="relative min-h-[60vh] lg:min-h-[70vh] flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0">
    <img src="/images/services/ceremony-caldera.jpg" alt={t('hero.imageAlt')} class="w-full h-full object-cover object-top" />
    <div class="absolute inset-0 bg-gradient-to-b from-near-black/70 via-near-black/50 to-near-black/70"></div>
  </div>
  <div class="container-content px-6 lg:px-12 text-center relative z-10">
    <h1 class="text-display-sm md:text-display lg:text-display-lg font-serif italic text-white leading-tight mb-6" data-reveal>
      {t('hero.title')}
    </h1>
    <p class="text-sm md:text-base font-sans tracking-widest-plus uppercase text-white/60" data-reveal>
      {t('hero.subtitle')}
    </p>
  </div>
</section>

<!-- Philosophy -->
<section class="bg-white py-20 lg:py-28 px-6 lg:px-12">
  <div class="container-content max-w-narrow mx-auto text-center" data-reveal>
    <div class="flex items-center justify-center gap-3 mb-10">
      <div class="w-10 h-px bg-gold"></div>
      <div class="w-1.5 h-1.5 rounded-full bg-gold"></div>
      <div class="w-10 h-px bg-gold"></div>
    </div>
    <p class="text-base md:text-lg font-serif text-grey leading-relaxed">
      {t('philosophy.body')}
    </p>
  </div>
</section>

<!-- Planning Services -->
<section class="bg-off-white py-20 lg:py-28 px-6 lg:px-12">
  <div class="container-content max-w-narrow mx-auto">

    <!-- Category A: Full Wedding Planning -->
    <div class="mb-20" data-reveal>
      <div class="text-center mb-10">
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
          {t('fullPlanning.eyebrow')}
        </p>
        <h2 class="text-display-sm font-serif italic text-charcoal mb-4">
          {t('fullPlanning.heading')}
        </h2>
        <p class="text-sm text-grey leading-relaxed max-w-lg mx-auto">
          {t('fullPlanning.intro')}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {fullPlanningTiers.map((service, i) => (
          <div
            class="bg-white border border-gold/20 p-8 lg:p-10 hover:border-gold/50 transition-colors duration-300 flex flex-col"
            style={`transition-delay: ${i * 100}ms`}
          >
            <h3 class="text-xl font-serif italic text-charcoal mb-3">{service.name}</h3>
            <p class="text-lg font-sans font-medium text-forest-green mb-5">
              {service.startingFrom ? `${startingFromLabel} ${service.price}` : service.price}
            </p>
            <div class="w-8 h-px bg-gold/40 mb-5"></div>
            <ul class="space-y-2.5 text-sm text-grey/90 mb-8">
              {service.includes.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-2 w-1 h-1 rounded-full bg-gold/60 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a
              href={contactHref}
              class="mt-auto inline-flex items-center justify-center px-7 py-3 bg-forest-green text-white text-xs font-sans font-medium tracking-[0.12em] uppercase hover:bg-green-light transition-all duration-300"
            >
              {t('bookNow')}
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- Category B: Elopements -->
    <div class="mb-20" data-reveal>
      <div class="text-center mb-10">
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
          {t('elopements.eyebrow')}
        </p>
        <h2 class="text-display-sm font-serif italic text-charcoal mb-4">
          {t('elopements.heading')}
        </h2>
        <p class="text-sm text-grey leading-relaxed max-w-lg mx-auto">
          {t('elopements.intro')}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {elopementTiers.map((service, i) => (
          <div
            class="bg-white border border-gold/20 p-8 lg:p-10 hover:border-gold/50 transition-colors duration-300 flex flex-col"
            style={`transition-delay: ${i * 100}ms`}
          >
            <h3 class="text-xl font-serif italic text-charcoal mb-3">{service.name}</h3>
            <p class="text-lg font-sans font-medium text-forest-green mb-1">{service.price}</p>
            <p class="text-xs text-grey/70 italic mb-5">{t('elopements.basedOn')}</p>
            <div class="w-8 h-px bg-gold/40 mb-5"></div>
            <ul class="space-y-2.5 text-sm text-grey/90 mb-8">
              {service.includes.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-2 w-1 h-1 rounded-full bg-gold/60 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a
              href={contactHref}
              class="mt-auto inline-flex items-center justify-center px-7 py-3 bg-forest-green text-white text-xs font-sans font-medium tracking-[0.12em] uppercase hover:bg-green-light transition-all duration-300"
            >
              {t('bookNow')}
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- Category C: Proposals & Vow Renewals -->
    <div class="mb-20" data-reveal>
      <div class="text-center mb-10">
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
          {t('proposals.eyebrow')}
        </p>
        <h2 class="text-display-sm font-serif italic text-charcoal mb-4">
          {t('proposals.heading')}
        </h2>
        <p class="text-sm text-grey leading-relaxed max-w-lg mx-auto">
          {t('proposals.intro')}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {proposalTiers.map((service, i) => (
          <div
            class="bg-white border border-gold/20 p-8 lg:p-10 hover:border-gold/50 transition-colors duration-300 flex flex-col"
            style={`transition-delay: ${i * 100}ms`}
          >
            <h3 class="text-xl font-serif italic text-charcoal mb-3">{service.name}</h3>
            <p class="text-lg font-sans font-medium text-forest-green mb-1">{service.price}</p>
            <p class="text-xs text-grey/70 italic mb-5">{t('proposals.basedOn')}</p>
            <div class="w-8 h-px bg-gold/40 mb-5"></div>
            <ul class="space-y-2.5 text-sm text-grey/90 mb-8">
              {service.includes.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-2 w-1 h-1 rounded-full bg-gold/60 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a
              href={contactHref}
              class="mt-auto inline-flex items-center justify-center px-7 py-3 bg-forest-green text-white text-xs font-sans font-medium tracking-[0.12em] uppercase hover:bg-green-light transition-all duration-300"
            >
              {t('bookNow')}
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- Category D: Sailing Experience -->
    <div class="mb-20" data-reveal>
      <div class="text-center mb-10">
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
          {t('sailing.eyebrow')}
        </p>
        <h2 class="text-display-sm font-serif italic text-charcoal mb-2">
          {t('sailing.heading')}
        </h2>
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-grey/70 mb-4">
          {t('sailing.subEyebrow')}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:max-w-xl md:mx-auto">
        {sailingTiers.map((service, i) => (
          <div
            class="bg-white border border-gold/20 p-8 lg:p-10 hover:border-gold/50 transition-colors duration-300 flex flex-col md:col-span-2"
            style={`transition-delay: ${i * 100}ms`}
          >
            <h3 class="text-xl font-serif italic text-charcoal mb-3">{service.name}</h3>
            <p class="text-lg font-sans font-medium text-forest-green mb-1">{service.price}</p>
            <p class="text-xs text-grey/70 italic mb-5">{t('sailing.basedOn')}</p>
            <div class="w-8 h-px bg-gold/40 mb-5"></div>
            <ul class="space-y-2.5 text-sm text-grey/90 mb-8">
              {service.includes.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-2 w-1 h-1 rounded-full bg-gold/60 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a
              href={contactHref}
              class="mt-auto inline-flex items-center justify-center px-7 py-3 bg-forest-green text-white text-xs font-sans font-medium tracking-[0.12em] uppercase hover:bg-green-light transition-all duration-300"
            >
              {t('bookNow')}
            </a>
          </div>
        ))}
      </div>
    </div>

    <p class="text-center text-sm text-grey/80 italic" data-reveal>
      {t('addons.note')}
    </p>

  </div>
</section>

<!-- The Panos Antoniou Advantage -->
<section class="bg-white py-20 lg:py-28 px-6 lg:px-12">
  <div class="container-content">
    <div class="text-center mb-14" data-reveal>
      <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
        {t('advantage.eyebrow')}
      </p>
      <h2 class="text-display-sm md:text-display font-serif italic text-charcoal">
        {t('advantage.heading')}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {advantageItems.map((item, i) => (
        <div class="text-center" data-reveal style={`transition-delay: ${i * 100}ms`}>
          <div class="w-12 h-12 rounded-full bg-off-white border border-gold/30 flex items-center justify-center mx-auto mb-5">
            {i === 0 && (
              <svg class="w-6 h-6 text-charcoal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            )}
            {i === 1 && (
              <svg class="w-6 h-6 text-charcoal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            )}
            {i === 2 && (
              <svg class="w-6 h-6 text-charcoal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
          </div>
          <h3 class="text-base font-serif italic text-charcoal mb-3">{item.title}</h3>
          <p class="text-sm text-grey leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<CTABanner
  title={t('cta.title')}
  buttonText={t('cta.buttonText')}
  buttonHref={contactHref}
/>
