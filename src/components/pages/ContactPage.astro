---
import enDict from '../../i18n/en/contact';
import elDict from '../../i18n/el/contact';
import { isLocale, useTranslations, type Locale } from '../../i18n/utils';

const lang: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'en';
const t = useTranslations({ en: enDict, el: elDict }, lang);
---

<!-- Hero -->
<section class="relative py-24 lg:py-32 overflow-hidden">
  <div class="absolute inset-0">
    <img src="/images/scenery/santorini-village.jpg" alt="" class="w-full h-full object-cover object-center" />
    <div class="absolute inset-0 bg-gradient-to-b from-forest-green/80 via-forest-green/70 to-green-light/80"></div>
  </div>
  <div class="relative z-10 container-content text-center px-6">
    <h1 class="text-display-sm md:text-display lg:text-display-lg font-serif italic text-white mb-4" data-reveal>
      {t('hero.title')}
    </h1>
    <div class="flex items-center justify-center gap-3" data-reveal>
      <div class="w-10 h-px bg-gold"></div>
      <div class="w-1 h-1 rounded-full bg-gold"></div>
      <div class="w-10 h-px bg-gold"></div>
    </div>
  </div>
</section>

<!-- Main Content -->
<section class="bg-white">
  <div class="container-content px-6 lg:px-12 py-20 lg:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16 lg:gap-20">

      <!-- Form Column (2/3) -->
      <div class="lg:col-span-2" data-reveal>
        <div id="form-container">
          <form id="contact-form" class="space-y-6">
            <!-- Web3Forms config -->
            <input type="hidden" name="access_key" value="f6874fe8-576a-42f5-8f14-a49465b92dfb" />
            <input type="hidden" name="subject" value="New Inquiry — Panos Antoniou Weddings" />
            <input type="hidden" name="from_name" value="Panos Antoniou Weddings — Website" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

            <!-- Full Name -->
            <div>
              <label for="name" class="block text-sm font-sans font-medium text-charcoal mb-2">{t('form.labels.name')}</label>
              <input
                type="text"
                id="name"
                name="name"
                class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                placeholder={t('form.placeholders.name')}
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-sans font-medium text-charcoal mb-2">{t('form.labels.email')} <span class="text-red-500">{t('form.required')}</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                placeholder={t('form.placeholders.email')}
              />
            </div>

            <!-- WhatsApp / Mobile -->
            <div>
              <label for="phone" class="block text-sm font-sans font-medium text-charcoal mb-2">{t('form.labels.phone')} <span class="text-red-500">{t('form.required')}</span></label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                placeholder={t('form.placeholders.phone')}
              />
            </div>

            <!-- Event Date -->
            <div>
              <label for="date" class="block text-sm font-sans font-medium text-charcoal mb-2">{t('form.labels.eventDate')} <span class="text-grey/60 font-normal">{t('form.labels.eventDateFormat')}</span></label>
              <input
                type="date"
                id="date"
                name="event_date"
                lang="en-GB"
                class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
              />
            </div>

            <!-- Event Location -->
            <div>
              <label for="location" class="block text-sm font-sans font-medium text-charcoal mb-2">{t('form.labels.eventLocation')}</label>
              <input
                type="text"
                id="location"
                name="event_location"
                class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                placeholder={t('form.placeholders.eventLocation')}
              />
            </div>

            <!-- Service Selection -->
            <div>
              <label for="service" class="block text-sm font-sans font-medium text-charcoal mb-2">{t('form.labels.service')}</label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
              >
                <option value="">{t('form.serviceOptions.placeholder')}</option>
                <optgroup label={t('form.serviceOptions.beautyGroup')}>
                  <option value="bridal-makeup">{t('form.serviceOptions.bridal')}</option>
                  <option value="photoshooting-makeup">{t('form.serviceOptions.photoshooting')}</option>
                  <option value="basic-makeup">{t('form.serviceOptions.basic')}</option>
                </optgroup>
                <optgroup label={t('form.serviceOptions.planningGroup')}>
                  <option value="full-planning">{t('form.serviceOptions.fullPlanning')}</option>
                  <option value="elopement">{t('form.serviceOptions.elopement')}</option>
                  <option value="proposal">{t('form.serviceOptions.proposal')}</option>
                </optgroup>
                <optgroup label={t('form.serviceOptions.combinedGroup')}>
                  <option value="combined">{t('form.serviceOptions.combinedCustom')}</option>
                </optgroup>
              </select>
            </div>

            <!-- Budget -->
            <div>
              <label for="budget" class="block text-sm font-sans font-medium text-charcoal mb-2">{t('form.labels.budget')}</label>
              <input
                type="text"
                id="budget"
                name="budget"
                inputmode="numeric"
                class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                placeholder={t('form.placeholders.budget')}
              />
            </div>

            <!-- How did you find us? -->
            <div>
              <label for="referral" class="block text-sm font-sans font-medium text-charcoal mb-2">{t('form.labels.referral')} <span class="text-red-500">{t('form.required')}</span></label>
              <input
                type="text"
                id="referral"
                name="referral_source"
                list="referral-options"
                required
                class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                placeholder={t('form.placeholders.referral')}
              />
              <datalist id="referral-options">
                <option value={t('form.referralOptions.google')}></option>
                <option value={t('form.referralOptions.instagram')}></option>
                <option value={t('form.referralOptions.tiktok')}></option>
                <option value={t('form.referralOptions.facebook')}></option>
                <option value={t('form.referralOptions.pinterest')}></option>
                <option value={t('form.referralOptions.friend')}></option>
                <option value={t('form.referralOptions.weddingBlog')}></option>
                <option value={t('form.referralOptions.other')}></option>
              </datalist>
            </div>

            <!-- Your Vision -->
            <div>
              <label for="vision" class="block text-sm font-sans font-medium text-charcoal mb-2">{t('form.labels.vision')}</label>
              <textarea
                id="vision"
                name="vision"
                rows="5"
                class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors resize-none"
                placeholder={t('form.placeholders.vision')}
              ></textarea>
            </div>

            <!-- Error message (hidden by default) -->
            <div id="form-error" role="alert" class="hidden px-4 py-3 bg-red-50 border border-red-200 text-red-700 text-sm rounded-sm">
              {t('form.error')}
            </div>

            <!-- Submit -->
            <button
              id="submit-btn"
              type="submit"
              data-label-default={t('form.submit')}
              data-label-submitting={t('form.submitting')}
              class="w-full py-4 bg-forest-green text-white text-sm font-sans font-medium tracking-widest uppercase hover:bg-green-light transition-colors duration-300 disabled:opacity-60 disabled:cursor-not-allowed"
            >
              <span id="submit-label">{t('form.submit')}</span>
            </button>
          </form>
        </div>

        <!-- Success Message (hidden by default) -->
        <div id="success-message" style="display: none;" class="text-center py-16">
          <div class="w-16 h-16 rounded-full bg-forest-green/10 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-forest-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-display-sm font-serif italic text-charcoal mb-4">{t('form.success.heading')}</h3>
          <p class="text-base text-grey leading-relaxed mb-6 max-w-md mx-auto">
            {t('form.success.body')}
          </p>
          <a
            href="https://wa.me/306955628019"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-8 py-3 bg-[#25D366] text-white text-sm font-sans font-medium tracking-wider uppercase rounded-sm hover:bg-[#20bd5a] transition-colors duration-300"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            {t('form.success.whatsappCta')}
          </a>
        </div>
      </div>

