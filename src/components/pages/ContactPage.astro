</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const formEl = document.getElementById('form-container');
  const successEl = document.getElementById('success-message');
  const errorEl = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('submit-label');

  const defaultLabel = submitBtn?.dataset.labelDefault ?? submitLabel?.textContent ?? 'Send';
  const submittingLabel = submitBtn?.dataset.labelSubmitting ?? 'Sending…';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    errorEl?.classList.add('hidden');
    if (submitBtn) submitBtn.disabled = true;
    if (submitLabel) submitLabel.textContent = submittingLabel;

    const formData = new FormData(form);

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData,
      });
      const data = await response.json();

      if (response.ok && data.success) {
        if (formEl) formEl.style.display = 'none';
        if (successEl) successEl.style.display = 'block';
        form.reset();
      } else {
        if (import.meta.env.DEV) console.error('Web3Forms response not ok', data);
        errorEl?.classList.remove('hidden');
        if (submitBtn) submitBtn.disabled = false;
        if (submitLabel) submitLabel.textContent = defaultLabel;
      }
    } catch (err) {
      if (import.meta.env.DEV) console.error('Contact form submission failed', err);
      errorEl?.classList.remove('hidden');
      if (submitBtn) submitBtn.disabled = false;
      if (submitLabel) submitLabel.textContent = defaultLabel;
    }
  });
</script>
