---
import { services } from '../../data/services';
import SectionHeading from '../ui/SectionHeading.astro';
import PlaceholderImage from '../ui/PlaceholderImage.astro';
---

<section class="section-padding bg-cream">
  <div class="container-content">
    <SectionHeading
      eyebrow="What We Offer"
      title="Our Services"
      description="From bridal beauty to professional training, every service is crafted with precision, discretion, and a deep understanding of modern luxury."
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {services.map((service, i) => (
        <a
          href={service.slug}
          class="group block"
          data-reveal
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class="relative overflow-hidden rounded-sm aspect-[3/4] mb-5">
            <div class="w-full h-full transition-transform duration-700 group-hover:scale-105">
              <PlaceholderImage src={service.image} alt={service.title} label={service.title} />
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-brown-dark/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          </div>
          <h3 class="text-lg font-serif italic text-brown-dark mb-2 group-hover:text-accent transition-colors duration-300">
            {service.title}
          </h3>
          <p class="text-sm text-accent-light leading-relaxed">
            {service.description}
          </p>
          <span class="inline-flex items-center gap-2 mt-3 text-xs font-sans font-medium tracking-widest uppercase text-accent group-hover:gap-3 transition-all duration-300">
            Learn More
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
