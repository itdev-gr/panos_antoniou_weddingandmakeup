---
import { portfolioItems } from '../../data/portfolio';
import SectionHeading from '../ui/SectionHeading.astro';
import Button from '../ui/Button.astro';
import PlaceholderImage from '../ui/PlaceholderImage.astro';

const featured = portfolioItems.slice(0, 6);
---

<section class="section-padding bg-sand">
  <div class="container-content">
    <SectionHeading
      eyebrow="Our Work"
      title="Portfolio"
      description="Every bride is unique. Every look, unforgettable."
    />

    <!-- Asymmetric Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 lg:gap-4 mb-12">
      {featured.map((item, i) => (
        <div
          class:list={[
            "relative overflow-hidden rounded-sm group cursor-pointer",
            i === 0 ? "row-span-2 aspect-[3/4]" : "aspect-square",
            i === 3 ? "lg:col-span-2 lg:aspect-[2/1]" : "",
          ]}
          data-reveal
          style={`transition-delay: ${i * 80}ms`}
        >
          <div class="w-full h-full transition-transform duration-700 group-hover:scale-105">
            <PlaceholderImage src={item.src} alt={item.alt} label={item.caption} />
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-brown-dark/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-5">
            <p class="text-sm font-serif italic text-cream">{item.caption}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center" data-reveal>
      <Button variant="outline" href="/portfolio">View Full Portfolio</Button>
    </div>
  </div>
</section>
