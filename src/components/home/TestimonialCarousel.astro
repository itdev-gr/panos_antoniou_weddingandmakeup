---
import { testimonials } from '../../data/testimonials';
---

<section class="section-padding bg-brown-dark relative overflow-hidden">
  <!-- Decorative -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-cream/10 to-transparent"></div>

  <div class="container-content text-center">
    <p class="text-xs font-sans font-medium tracking-ultra-wide uppercase text-cream/40 mb-8">Testimonials</p>

    <div class="relative max-w-2xl mx-auto">
      <!-- Decorative Quote Mark -->
      <div class="text-6xl font-serif text-cream/10 leading-none mb-4">&ldquo;</div>

      <!-- Carousel -->
      <div id="testimonial-track" class="overflow-hidden">
        <div class="flex transition-transform duration-700 ease-in-out" id="testimonial-slider">
          {testimonials.map((t) => (
            <div class="w-full flex-shrink-0 px-4">
              <blockquote class="text-xl md:text-2xl font-serif italic text-cream/80 leading-relaxed mb-8">
                {t.quote}
              </blockquote>
              <div class="w-8 h-px bg-cream/20 mx-auto mb-4"></div>
              <cite class="not-italic">
                <span class="text-sm font-sans font-medium text-cream/60">{t.name}</span>
                <span class="text-xs font-sans text-cream/30 block mt-1">{t.location}</span>
              </cite>
            </div>
          ))}
        </div>
      </div>

      <!-- Dots -->
      <div class="flex justify-center gap-2 mt-10" id="testimonial-dots">
        {testimonials.map((_, i) => (
          <button
            class:list={[
              "w-2 h-2 rounded-full transition-all duration-300",
              i === 0 ? "bg-cream/60 w-6" : "bg-cream/20",
            ]}
            data-index={i}
            aria-label={`Testimonial ${i + 1}`}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const slider = document.getElementById('testimonial-slider');
  const dots = document.querySelectorAll('#testimonial-dots button');
  let current = 0;
  const total = dots.length;

  function goTo(index: number) {
    current = index;
    if (slider) slider.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-cream/60', i === current);
      dot.classList.toggle('w-6', i === current);
      dot.classList.toggle('bg-cream/20', i !== current);
      dot.classList.toggle('w-2', i !== current);
    });
  }

  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

  // Auto-advance every 6s
  setInterval(() => goTo((current + 1) % total), 6000);
</script>
