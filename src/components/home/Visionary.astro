---
import enHome from '../../i18n/en/home';
import elHome from '../../i18n/el/home';
import { isLocale, useTranslations, localizedPath, type Locale } from '../../i18n/utils';
const lang: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'en';
const t = useTranslations({ en: enHome, el: elHome }, lang);
---
<section class="bg-white py-24 lg:py-32 px-6 lg:px-12">
  <div class="container-content">
    <p class="text-[10px] font-sans font-medium tracking-[0.2em] uppercase text-gold text-center mb-3">
      {t('visionary.eyebrow')}
    </p>
    <div class="flex items-center justify-center gap-3 mb-12">
      <div class="w-10 h-px bg-gold"></div>
      <div class="w-1 h-1 rounded-full bg-gold"></div>
      <div class="w-10 h-px bg-gold"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center" data-reveal>
      <video
        src="/videos/makeup-artist.mp4"
        poster="/images/about/panos-portrait.jpg"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-label="Panos Antoniou bridal makeup artist Santorini"
        class="w-full h-auto object-cover rounded-sm"
      ></video>
      <div>
        <p class="text-base font-light text-grey leading-relaxed mb-5">
          {t('visionary.p1')}
        </p>
        <p class="text-base font-light text-grey leading-relaxed mb-5">
          {t('visionary.p2BeforeLink')}<a href={localizedPath('/services/wedding-planning', lang)} class="text-forest-green hover:underline">{t('visionary.p2LinkText')}</a>{t('visionary.p2AfterLink')}
        </p>
        <p class="text-sm text-grey/70 leading-relaxed">
          {t('visionary.p3')}
        </p>
      </div>
    </div>
  </div>
</section>
