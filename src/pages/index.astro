---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/home/Hero.astro';
import ServiceHighlights from '../components/home/ServiceHighlights.astro';
import PortfolioShowcase from '../components/home/PortfolioShowcase.astro';
import TestimonialCarousel from '../components/home/TestimonialCarousel.astro';
import AboutTeaser from '../components/home/AboutTeaser.astro';
import CTABanner from '../components/home/CTABanner.astro';
import Button from '../components/ui/Button.astro';
import PlaceholderImage from '../components/ui/PlaceholderImage.astro';
import { testimonials } from '../data/testimonials';
import { locations } from '../data/services';

const blogPosts = [
  {
    title: "How to Have the Perfect Santorini Dream Wedding",
    slug: "/blog/santorini-dream-wedding",
    excerpt: "Santorini is one of the most sought-after wedding destinations in the world. Here's everything you need to know.",
    date: "June 23, 2021",
    image: "/images/portfolio/santorini-bridal-looks-3.jpg",
    category: "Wedding Planning",
  },
  {
    title: "How to Select Your Wedding Beautician",
    slug: "/blog/wedding-beautician",
    excerpt: "Choosing the right makeup artist for your wedding is one of the most important decisions you'll make.",
    date: "June 4, 2021",
    image: "/images/portfolio/glam-makeup-hair.jpg",
    category: "Bridal Tips",
  },
  {
    title: "Get Access to the Best Wedding Makeup Services",
    slug: "/blog/best-wedding-makeup-services",
    excerpt: "From budgeting to trials, discover the five essential factors for the best wedding makeup services.",
    date: "May 15, 2021",
    image: "/images/portfolio/luxury-glam-brides-santorini.jpg",
    category: "Bridal Beauty",
  },
];

const quote = testimonials[0];
---

<PageLayout
  title="Panos Antoniou — Luxury Wedding Makeup & Hair | Santorini"
  description="Luxury bridal makeup & hair services by Panos Antoniou. 26+ years of experience in Santorini, Mykonos, Athens & worldwide destination weddings."
  transparentHeader={true}
>
  <!-- 1. Hero -->
  <Hero />

  <!-- 2. Editorial Intro -->
  <section class="relative section-padding bg-cream">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-muted/40 to-transparent"></div>

    <div class="container-content max-w-narrow text-center">
      <div data-reveal>
        <div class="inline-flex items-center gap-4 mb-6">
          <div class="w-8 h-px bg-gold-muted"></div>
          <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-accent-light">Welcome</p>
          <div class="w-8 h-px bg-gold-muted"></div>
        </div>
        <h2 class="text-display-sm md:text-display font-serif italic text-brown-dark mb-6">
          Where Beauty Meets Artistry
        </h2>
        <div class="w-12 h-px bg-gold-muted mx-auto mb-6"></div>
        <p class="text-base text-accent-light leading-relaxed mb-4">
          For over 26 years, Panos Antoniou has been transforming wedding mornings into unforgettable experiences. From the sun-kissed cliffs of Santorini to exclusive venues across Europe and beyond, every bride receives the same unwavering commitment to perfection.
        </p>
        <p class="text-base text-accent-light leading-relaxed">
          Whether it's bridal makeup, hair styling, bridesmaid coordination, or editorial shoots — we bring discretion, precision, and a deep understanding of modern luxury to every occasion.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Services -->
  <ServiceHighlights />

  <!-- 4. Pull Quote Interlude -->
  <section class="py-20 lg:py-24 bg-brown-dark">
    <div class="container-content max-w-narrow text-center px-6">
      <div class="text-5xl font-serif text-cream/10 leading-none mb-4">&ldquo;</div>
      <p class="text-xl md:text-2xl font-serif italic text-cream/80 leading-relaxed mb-6" data-reveal>
        {quote.quote}
      </p>
      <div class="w-8 h-px bg-cream/20 mx-auto mb-4"></div>
      <p class="text-sm font-sans text-cream/40">{quote.name} — {quote.location}</p>
    </div>
  </section>

  <!-- 5. Portfolio Showcase -->
  <PortfolioShowcase />

  <!-- 6. Meet the Artist -->
  <AboutTeaser />

  <!-- 7. Destinations -->
  <section class="relative section-padding bg-sand/50">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-muted/40 to-transparent"></div>

    <div class="container-content text-center">
      <div data-reveal>
        <div class="inline-flex items-center gap-4 mb-6">
          <div class="w-8 h-px bg-gold-muted"></div>
          <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-accent-light">Where We Work</p>
          <div class="w-8 h-px bg-gold-muted"></div>
        </div>
        <h2 class="text-display-sm md:text-display font-serif italic text-brown-dark mb-6">
          Destination Specialist
        </h2>
        <div class="w-12 h-px bg-gold-muted mx-auto mb-6"></div>
        <p class="text-base text-accent-light leading-relaxed max-w-2xl mx-auto mb-12">
          Based in Santorini with a passion for travel, Panos serves brides at the world's most beautiful wedding destinations. No venue is too remote, no occasion too ambitious.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-4 lg:gap-6" data-reveal style="transition-delay: 150ms">
        {locations.map((location) => (
          <div class="px-6 py-3 border border-gold-muted/40 rounded-full">
            <span class="text-sm font-serif italic text-brown-dark">{location}</span>
          </div>
        ))}
      </div>

      <div class="mt-12" data-reveal style="transition-delay: 250ms">
        <Button variant="outline" href="/contact">Plan Your Destination Wedding</Button>
      </div>
    </div>
  </section>

  <!-- 8. Testimonials Carousel -->
  <TestimonialCarousel />

  <!-- 9. Blog Preview -->
  <section class="relative section-padding bg-cream">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-muted/40 to-transparent"></div>

    <div class="container-content">
      <div class="text-center mb-12 lg:mb-16">
        <div class="inline-flex items-center gap-4 mb-6" data-reveal>
          <div class="w-8 h-px bg-gold-muted"></div>
          <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-accent-light">Insights & Inspiration</p>
          <div class="w-8 h-px bg-gold-muted"></div>
        </div>
        <h2 class="text-display-sm md:text-display lg:text-display-lg font-serif italic text-brown-dark" data-reveal>
          From the Blog
        </h2>
        <div class="w-12 h-px bg-gold-muted mx-auto mt-5" data-reveal></div>
        <p class="mt-5 text-base max-w-2xl mx-auto text-accent-light leading-relaxed" data-reveal>
          Tips, stories, and expert advice to help you prepare for your perfect wedding day.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {blogPosts.map((post, i) => (
          <a
            href={post.slug}
            class="group block"
            data-reveal
            style={`transition-delay: ${i * 100}ms`}
          >
            <div class="aspect-[4/3] overflow-hidden rounded-sm mb-5">
              <div class="w-full h-full transition-transform duration-700 group-hover:scale-105">
                <PlaceholderImage src={post.image} alt={post.title} label={post.category} />
              </div>
            </div>
            <div class="flex items-center gap-3 mb-3">
              <span class="text-[10px] font-sans font-medium tracking-widest uppercase text-accent bg-sand px-3 py-1 rounded-full">
                {post.category}
              </span>
              <span class="text-xs text-accent-light/60">{post.date}</span>
            </div>
            <h3 class="text-lg font-serif italic text-brown-dark mb-2 group-hover:text-accent transition-colors duration-300">
              {post.title}
            </h3>
            <p class="text-sm text-accent-light leading-relaxed">
              {post.excerpt}
            </p>
          </a>
        ))}
      </div>

      <div class="text-center mt-12" data-reveal>
        <Button variant="outline" href="/blog">Read All Articles</Button>
      </div>
    </div>
  </section>

  <!-- 10. Reassurance Strip -->
  <section class="bg-sand/50 border-t border-sand-dark/50">
    <div class="container-content px-6 lg:px-12 py-12 lg:py-16">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 lg:gap-12 text-center">
        <div data-reveal>
          <div class="w-10 h-10 rounded-full bg-cream border border-sand-dark flex items-center justify-center mx-auto mb-4">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
            </svg>
          </div>
          <p class="text-sm font-serif italic text-brown-dark mb-1">26+ Years of Artistry</p>
          <p class="text-xs text-accent-light/60">Thousands of brides worldwide</p>
        </div>
        <div data-reveal style="transition-delay: 100ms">
          <div class="w-10 h-10 rounded-full bg-cream border border-sand-dark flex items-center justify-center mx-auto mb-4">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <p class="text-sm font-serif italic text-brown-dark mb-1">Destination Specialist</p>
          <p class="text-xs text-accent-light/60">Greece, Europe & beyond</p>
        </div>
        <div data-reveal style="transition-delay: 200ms">
          <div class="w-10 h-10 rounded-full bg-cream border border-sand-dark flex items-center justify-center mx-auto mb-4">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
            </svg>
          </div>
          <p class="text-sm font-serif italic text-brown-dark mb-1">Luxury Approach</p>
          <p class="text-xs text-accent-light/60">Premium products & techniques</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 11. CTA Banner -->
  <CTABanner />
</PageLayout>
