---
import PageLayout from '../layouts/PageLayout.astro';
import HomePage from '../components/pages/HomePage.astro';
import CTABanner from '../components/home/CTABanner.astro';
import enHome from '../i18n/en/home';
import elHome from '../i18n/el/home';
import { isLocale, useTranslations, localizedPath, type Locale } from '../i18n/utils';
const lang: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'en';
const t = useTranslations({ en: enHome, el: elHome }, lang);
---
<PageLayout
  title={t('meta.title')}
  description={t('meta.description')}
  image="/images/hero/hero-santorini-sunset.jpg"
  transparentHeader={true}
>
  <HomePage />
  <CTABanner
    title={t('cta.title')}
    description={t('cta.description')}
    buttonText={t('cta.buttonText')}
    buttonHref={localizedPath('/contact', lang)}
  />
</PageLayout>
