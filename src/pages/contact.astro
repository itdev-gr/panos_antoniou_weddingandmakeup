---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Book Your Santorini Wedding Experience | Panos Antoniou Weddings"
  description="Ready to start planning your Santorini wedding? Contact Panos Antoniou Weddings for bridal beauty and event design. Secure your date for 2026/2027."
>
  <!-- Hero -->
  <section class="relative py-24 lg:py-32 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/scenery/santorini-village.jpg" alt="" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-gradient-to-b from-forest-green/80 via-forest-green/70 to-green-light/80"></div>
    </div>
    <div class="relative z-10 container-content text-center px-6">
      <h1 class="text-display-sm md:text-display lg:text-display-lg font-serif italic text-white mb-4" data-reveal>
        Book Your Santorini Wedding Experience
      </h1>
      <div class="flex items-center justify-center gap-3" data-reveal>
        <div class="w-10 h-px bg-gold"></div>
        <div class="w-1 h-1 rounded-full bg-gold"></div>
        <div class="w-10 h-px bg-gold"></div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-white">
    <div class="container-content px-6 lg:px-12 py-20 lg:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16 lg:gap-20">

        <!-- Form Column (2/3) -->
        <div class="lg:col-span-2" data-reveal>
          <div id="form-container">
            <form id="contact-form" class="space-y-6">
              <!-- Full Name -->
              <div>
                <label for="name" class="block text-sm font-sans font-medium text-charcoal mb-2">Full Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                  placeholder="Your full name"
                />
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-sm font-sans font-medium text-charcoal mb-2">Email Address <span class="text-red-500">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                  placeholder="your@email.com"
                />
              </div>

              <!-- WhatsApp / Mobile -->
              <div>
                <label for="phone" class="block text-sm font-sans font-medium text-charcoal mb-2">WhatsApp / Mobile Number <span class="text-red-500">*</span></label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                  placeholder="+30 69X XXX XXXX"
                />
              </div>

              <!-- Event Date -->
              <div>
                <label for="date" class="block text-sm font-sans font-medium text-charcoal mb-2">Event Date <span class="text-grey/60 font-normal">(DD/MM/YYYY)</span></label>
                <input
                  type="date"
                  id="date"
                  name="event_date"
                  lang="en-GB"
                  class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                />
              </div>

              <!-- Event Location -->
              <div>
                <label for="location" class="block text-sm font-sans font-medium text-charcoal mb-2">Event Location</label>
                <input
                  type="text"
                  id="location"
                  name="event_location"
                  class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                  placeholder="e.g. Santo Wines, Santorini"
                />
              </div>

              <!-- Service Selection -->
              <div>
                <label for="service" class="block text-sm font-sans font-medium text-charcoal mb-2">Service Selection</label>
                <select
                  id="service"
                  name="service"
                  class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                >
                  <option value="">Select a service...</option>
                  <optgroup label="Makeup and Hair">
                    <option value="bridal-makeup">Bridal</option>
                    <option value="photoshooting-makeup">Photoshooting</option>
                    <option value="basic-makeup">Basic</option>
                  </optgroup>
                  <optgroup label="Wedding Planning & Design">
                    <option value="full-planning">Full Planning</option>
                    <option value="elopement">Elopement</option>
                    <option value="proposal">Proposal</option>
                  </optgroup>
                  <optgroup label="The Combined Experience">
                    <option value="combined">Custom Package</option>
                  </optgroup>
                </select>
              </div>

              <!-- Budget -->
              <div>
                <label for="budget" class="block text-sm font-sans font-medium text-charcoal mb-2">Budget (EUR)</label>
                <input
                  type="text"
                  id="budget"
                  name="budget"
                  inputmode="numeric"
                  class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                  placeholder="e.g. €3,500"
                />
              </div>

              <!-- How did you find us? -->
              <div>
                <label for="referral" class="block text-sm font-sans font-medium text-charcoal mb-2">How did you find us? <span class="text-red-500">*</span></label>
                <select
                  id="referral"
                  name="referral_source"
                  required
                  class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
                >
                  <option value="">Select an option...</option>
                  <option value="google">Google</option>
                  <option value="instagram">Instagram</option>
                  <option value="tiktok">TikTok</option>
                  <option value="facebook">Facebook</option>
                  <option value="pinterest">Pinterest</option>
                  <option value="friend-referral">Friend Referral</option>
                  <option value="wedding-blog">Wedding Blog</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <!-- Your Vision -->
              <div>
                <label for="vision" class="block text-sm font-sans font-medium text-charcoal mb-2">Your Vision</label>
                <textarea
                  id="vision"
                  name="vision"
                  rows="5"
                  class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors resize-none"
                  placeholder="Tell us about your vision for the day..."
                ></textarea>
              </div>

              <!-- Error message (hidden by default) -->
              <div id="form-error" role="alert" class="hidden px-4 py-3 bg-red-50 border border-red-200 text-red-700 text-sm rounded-sm">
                Something went wrong while sending your inquiry. Please try again, or reach us directly on WhatsApp.
              </div>

              <!-- Submit -->
              <button
                id="submit-btn"
                type="submit"
                class="w-full py-4 bg-forest-green text-white text-sm font-sans font-medium tracking-widest uppercase hover:bg-green-light transition-colors duration-300 disabled:opacity-60 disabled:cursor-not-allowed"
              >
                <span id="submit-label">Send Your Inquiry</span>
              </button>
            </form>
          </div>

          <!-- Success Message (hidden by default) -->
          <div id="success-message" style="display: none;" class="text-center py-16">
            <div class="w-16 h-16 rounded-full bg-forest-green/10 flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-forest-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </div>
            <h3 class="text-display-sm font-serif italic text-charcoal mb-4">Thank you for your inquiry!</h3>
            <p class="text-base text-grey leading-relaxed mb-6 max-w-md mx-auto">
              We'll get back to you within 24 hours. For a faster response, reach out via WhatsApp:
            </p>
            <a
              href="https://wa.me/306955628019"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-8 py-3 bg-[#25D366] text-white text-sm font-sans font-medium tracking-wider uppercase rounded-sm hover:bg-[#20bd5a] transition-colors duration-300"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Chat on WhatsApp
            </a>
          </div>
        </div>

        <!-- Contact Sidebar (1/3) -->
        <div class="lg:col-span-1" data-reveal style="transition-delay: 200ms">
          <div class="lg:sticky lg:top-32 space-y-8">

            <h3 class="text-lg font-serif italic text-charcoal">Get in Touch</h3>

            <!-- Email -->
            <a href="mailto:events@weddingsmakeupandhair.com" class="flex items-start gap-4 group">
              <div class="w-10 h-10 rounded-full bg-off-white flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-forest-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-sans font-medium tracking-widest uppercase text-grey/60 mb-1">Email</p>
                <p class="text-sm text-charcoal group-hover:text-forest-green transition-colors duration-300 break-all">events@weddingsmakeup<wbr/>andhair.com</p>
              </div>
            </a>

            <!-- WhatsApp / Mobile -->
            <a href="https://wa.me/306955628019" target="_blank" rel="noopener" class="flex items-start gap-4 group">
              <div class="w-10 h-10 rounded-full bg-off-white flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-forest-green" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <div>
                <p class="text-xs font-sans font-medium tracking-widest uppercase text-grey/60 mb-1">WhatsApp / Mobile</p>
                <p class="text-sm text-charcoal group-hover:text-forest-green transition-colors duration-300">+30 695 562 8019</p>
              </div>
            </a>

            <!-- Office -->
            <a href="tel:+302286022940" class="flex items-start gap-4 group">
              <div class="w-10 h-10 rounded-full bg-off-white flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-forest-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-sans font-medium tracking-widest uppercase text-grey/60 mb-1">Office</p>
                <p class="text-sm text-charcoal group-hover:text-forest-green transition-colors duration-300">+30 22860 22940</p>
              </div>
            </a>

            <!-- Location -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-off-white flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-forest-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-sans font-medium tracking-widest uppercase text-grey/60 mb-1">Location</p>
                <p class="text-sm text-charcoal">Pyrgos Village, Santorini, Greece</p>
              </div>
            </div>

            <!-- Social Links -->
            <div class="border-t border-gray-100 pt-8">
              <p class="text-xs font-sans font-medium tracking-widest uppercase text-grey/60 mb-4">Follow Us</p>
              <div class="flex gap-3">
                <a href="https://instagram.com/weddingsmakeupandhair" target="_blank" rel="noopener" class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-grey hover:bg-forest-green hover:border-forest-green hover:text-white transition-all duration-300" aria-label="Instagram">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
                <a href="https://facebook.com/panosantonioumakeuprtist" target="_blank" rel="noopener" class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-grey hover:bg-forest-green hover:border-forest-green hover:text-white transition-all duration-300" aria-label="Facebook">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href="https://www.tiktok.com/@panosantoniouweddings" target="_blank" rel="noopener" class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-grey hover:bg-forest-green hover:border-forest-green hover:text-white transition-all duration-300" aria-label="TikTok">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
                </a>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>
</PageLayout>

<script>
  import { addDoc, collection, serverTimestamp } from 'firebase/firestore';
  import { db, CONTACT_COLLECTION } from '../lib/firebase';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const formEl = document.getElementById('form-container');
  const successEl = document.getElementById('success-message');
  const errorEl = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('submit-label');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    errorEl?.classList.add('hidden');
    if (submitBtn) submitBtn.disabled = true;
    if (submitLabel) submitLabel.textContent = 'Sending…';

    const data = new FormData(form);
    const payload = {
      name: String(data.get('name') || '').trim(),
      email: String(data.get('email') || '').trim(),
      phone: String(data.get('phone') || '').trim(),
      eventDate: String(data.get('event_date') || '').trim(),
      eventLocation: String(data.get('event_location') || '').trim(),
      service: String(data.get('service') || '').trim(),
      budget: String(data.get('budget') || '').trim(),
      referralSource: String(data.get('referral_source') || '').trim(),
      message: String(data.get('vision') || '').trim(),
      createdAt: serverTimestamp(),
    };

    try {
      await addDoc(collection(db, CONTACT_COLLECTION), payload);
      if (formEl) formEl.style.display = 'none';
      if (successEl) successEl.style.display = 'block';
    } catch (err) {
      if (import.meta.env.DEV) console.error('Contact form submission failed', err);
      errorEl?.classList.remove('hidden');
      if (submitBtn) submitBtn.disabled = false;
      if (submitLabel) submitLabel.textContent = 'Send Your Inquiry';
    }
  });
</script>
