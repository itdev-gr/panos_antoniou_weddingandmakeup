---
import PageLayout from '../layouts/PageLayout.astro';
import ContactPage from '../components/pages/ContactPage.astro';
import enDict from '../i18n/en/contact';
import elDict from '../i18n/el/contact';
import { isLocale, useTranslations, localizedPath, type Locale } from '../i18n/utils';

const lang: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'en';
const t = useTranslations({ en: enDict, el: elDict }, lang);

const SITE = 'https://www.weddingsmakeupandhair.com';

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${SITE}${localizedPath('/contact', lang)}#contactpage`,
  "url": `${SITE}${localizedPath('/contact', lang)}`,
  "name": t('meta.title'),
  "description": t('meta.description'),
  "isPartOf": { "@id": `${SITE}/#website` },
  "about": { "@id": `${SITE}/#business` },
  "mainEntity": {
    "@type": "Organization",
    "@id": `${SITE}/#business`,
    "name": "Panos Antoniou Weddings",
    "contactPoint": [
      { "@type": "ContactPoint", "telephone": "+30-695-562-8019", "contactType": "customer service", "areaServed": ["GR", "Worldwide"], "availableLanguage": ["English", "Greek"] },
      { "@type": "ContactPoint", "telephone": "+30-22860-22940", "contactType": "office", "areaServed": "GR", "availableLanguage": ["English", "Greek"] },
      { "@type": "ContactPoint", "email": "events@weddingsmakeupandhair.com", "contactType": "booking", "availableLanguage": ["English", "Greek"] },
    ],
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": lang === 'el' ? 'Αρχική' : 'Home', "item": `${SITE}${localizedPath('/', lang)}` },
    { "@type": "ListItem", "position": 2, "name": lang === 'el' ? 'Επικοινωνία' : 'Contact', "item": `${SITE}${localizedPath('/contact', lang)}` },
  ],
};
---

<PageLayout
  title={t('meta.title')}
  description={t('meta.description')}
  image="/images/scenery/santorini-village.jpg"
  additionalSchema={[contactPageSchema, breadcrumbSchema]}
>
  <ContactPage />
</PageLayout>
