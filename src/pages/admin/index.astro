---
import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/png" href="/images/logo/panos-logo.png" />
    <title>Admin Dashboard | Panos Antoniou</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-off-white">
    <!-- Loading state -->
    <div id="loading" class="min-h-screen flex items-center justify-center">
      <p class="text-sm text-grey tracking-widest uppercase">Loading…</p>
    </div>

    <!-- Dashboard -->
    <div id="dashboard" class="hidden">
      <header class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-6 lg:px-10 py-5 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <img src="/images/logo/panos-logo.png" alt="Panos Antoniou" class="h-10 w-auto" />
            <div>
              <h1 class="text-lg font-serif italic text-charcoal leading-tight">Admin Dashboard</h1>
              <p class="text-[11px] text-grey tracking-wider uppercase">Contact Submissions</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <span id="user-email" class="hidden md:inline text-xs text-grey"></span>
            <button
              id="signout-btn"
              class="px-5 py-2.5 text-[11px] font-sans font-medium tracking-widest uppercase text-forest-green border border-forest-green hover:bg-forest-green hover:text-white transition-colors duration-300 rounded-sm"
            >
              Sign Out
            </button>
          </div>
        </div>
      </header>

      <main class="max-w-7xl mx-auto px-6 lg:px-10 py-10">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="text-2xl md:text-3xl font-serif italic text-charcoal">Inquiries</h2>
          <p id="submission-count" class="text-sm text-grey"></p>
        </div>

        <div id="empty-state" class="hidden bg-white border border-gray-200 rounded-sm p-16 text-center">
          <p class="text-base text-grey">No submissions yet.</p>
        </div>

        <div id="list" class="space-y-4"></div>
      </main>
    </div>

    <script>
      import { onAuthStateChanged, signOut } from 'firebase/auth';
      import { collection, getDocs, orderBy, query } from 'firebase/firestore';
      import { auth, db, CONTACT_COLLECTION } from '../../lib/firebase';

      const loadingEl = document.getElementById('loading');
      const dashboardEl = document.getElementById('dashboard');
      const listEl = document.getElementById('list');
      const countEl = document.getElementById('submission-count');
      const emptyEl = document.getElementById('empty-state');
      const signoutBtn = document.getElementById('signout-btn');
      const userEmailEl = document.getElementById('user-email');

      function escapeHtml(value: string): string {
        return value
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function formatDate(ts: any): string {
        if (!ts) return '—';
        const date = typeof ts.toDate === 'function' ? ts.toDate() : new Date(ts);
        if (isNaN(date.getTime())) return '—';
        return date.toLocaleString('en-GB', {
          day: '2-digit',
          month: 'short',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });
      }

      function row(labelText: string, valueText: string) {
        if (!valueText) return '';
        return `
          <div class="grid grid-cols-3 gap-3 py-2 border-b border-gray-100 last:border-b-0">
            <dt class="col-span-1 text-[11px] font-sans font-medium tracking-widest uppercase text-grey">${escapeHtml(labelText)}</dt>
            <dd class="col-span-2 text-sm text-charcoal break-words whitespace-pre-wrap">${escapeHtml(valueText)}</dd>
          </div>
        `;
      }

      async function loadSubmissions() {
        if (!listEl) return;
        listEl.innerHTML = '';
        try {
          const q = query(collection(db, CONTACT_COLLECTION), orderBy('createdAt', 'desc'));
          const snap = await getDocs(q);

          if (countEl) {
            countEl.textContent = `${snap.size} ${snap.size === 1 ? 'entry' : 'entries'}`;
          }

          if (snap.empty) {
            emptyEl?.classList.remove('hidden');
            return;
          }
          emptyEl?.classList.add('hidden');

          snap.forEach((doc) => {
            const d = doc.data() as Record<string, any>;
            const card = document.createElement('article');
            card.className = 'bg-white border border-gray-200 rounded-sm p-6 md:p-8';
            card.innerHTML = `
              <div class="flex items-baseline justify-between mb-4 gap-4 flex-wrap">
                <h3 class="text-lg font-serif italic text-charcoal">${escapeHtml(d.name || '(no name)')}</h3>
                <span class="text-xs text-grey tracking-wider">${escapeHtml(formatDate(d.createdAt))}</span>
              </div>
              <dl>
                ${row('Email', d.email || '')}
                ${row('Phone', d.phone || '')}
                ${row('Event Date', d.eventDate || '')}
                ${row('Event Location', d.eventLocation || '')}
                ${row('Service', d.service || '')}
                ${row('Budget', d.budget || '')}
                ${row('Found us via', d.referralSource || '')}
                ${row('Message', d.message || '')}
              </dl>
            `;
            listEl.appendChild(card);
          });
        } catch (err) {
          console.error('Failed to load submissions', err);
          listEl.innerHTML = `
            <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-sm p-6">
              Failed to load submissions. Check Firestore security rules and your network connection.
            </div>
          `;
        }
      }

      onAuthStateChanged(auth, (user) => {
        if (!user) {
          window.location.replace('/admin/login');
          return;
        }
        if (userEmailEl) userEmailEl.textContent = user.email || '';
        loadingEl?.classList.add('hidden');
        dashboardEl?.classList.remove('hidden');
        loadSubmissions();
      });

      signoutBtn?.addEventListener('click', async () => {
        await signOut(auth);
        window.location.replace('/admin/login');
      });
    </script>
  </body>
</html>
