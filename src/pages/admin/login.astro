---
import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/png" href="/images/logo/panos-logo.png" />
    <title>Admin Login | Panos Antoniou</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-off-white flex items-center justify-center px-6">
    <div class="w-full max-w-md bg-white border border-gray-200 rounded-sm shadow-sm p-10">
      <div class="text-center mb-8">
        <img src="/images/logo/panos-logo.png" alt="Panos Antoniou" class="h-14 w-auto mx-auto mb-4" />
        <h1 class="text-2xl font-serif italic text-charcoal">Admin Access</h1>
        <p class="text-sm text-grey mt-2">Sign in to view contact submissions.</p>
      </div>

      <form id="login-form" class="space-y-5">
        <div>
          <label for="email" class="block text-xs font-sans font-medium tracking-widest uppercase text-grey mb-2">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
          />
        </div>
        <div>
          <label for="password" class="block text-xs font-sans font-medium tracking-widest uppercase text-grey mb-2">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autocomplete="current-password"
            class="w-full px-4 py-3 bg-off-white border border-gray-200 text-charcoal text-sm focus:outline-none focus:ring-1 focus:ring-forest-green focus:border-forest-green transition-colors"
          />
        </div>

        <div id="login-error" role="alert" class="hidden px-4 py-3 bg-red-50 border border-red-200 text-red-700 text-sm rounded-sm"></div>

        <button
          id="login-btn"
          type="submit"
          class="w-full py-3.5 bg-forest-green text-white text-xs font-sans font-medium tracking-widest uppercase hover:bg-green-light transition-colors duration-300 disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <span id="login-label">Sign In</span>
        </button>
      </form>

      <p class="text-xs text-grey/70 text-center mt-6">
        <a href="/" class="hover:text-forest-green transition-colors">&larr; Back to site</a>
      </p>
    </div>

    <script>
      import { signInWithEmailAndPassword, onAuthStateChanged } from 'firebase/auth';
      import { auth } from '../../lib/firebase';

      const form = document.getElementById('login-form') as HTMLFormElement | null;
      const errorEl = document.getElementById('login-error');
      const btn = document.getElementById('login-btn') as HTMLButtonElement | null;
      const label = document.getElementById('login-label');

      onAuthStateChanged(auth, (user) => {
        if (user) window.location.replace('/admin');
      });

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const email = String(data.get('email') || '').trim();
        const password = String(data.get('password') || '');

        errorEl?.classList.add('hidden');
        if (errorEl) errorEl.textContent = '';
        if (btn) btn.disabled = true;
        if (label) label.textContent = 'Signing in…';

        try {
          await signInWithEmailAndPassword(auth, email, password);
          window.location.replace('/admin');
        } catch (err) {
          const msg = err instanceof Error ? err.message : 'Sign-in failed.';
          if (errorEl) {
            errorEl.textContent = msg.replace('Firebase: ', '');
            errorEl.classList.remove('hidden');
          }
          if (btn) btn.disabled = false;
          if (label) label.textContent = 'Sign In';
        }
      });
    </script>
  </body>
</html>
