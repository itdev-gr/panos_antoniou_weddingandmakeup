---
import PageLayout from '../../layouts/PageLayout.astro';
import PortfolioPage from '../../components/pages/PortfolioPage.astro';
import enDict from '../../i18n/en/portfolio';
import elDict from '../../i18n/el/portfolio';
import { isLocale, useTranslations, localizedPath, type Locale } from '../../i18n/utils';

const lang: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'el';
const t = useTranslations({ en: enDict, el: elDict }, lang);

const SITE = 'https://www.weddingsmakeupandhair.com';

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE}${localizedPath('/portfolio', lang)}#collection`,
  "url": `${SITE}${localizedPath('/portfolio', lang)}`,
  "name": t('meta.title'),
  "description": t('meta.description'),
  "isPartOf": { "@id": `${SITE}/#website` },
  "about": { "@id": `${SITE}/#business` },
  "inLanguage": lang === 'el' ? 'el-GR' : 'en-GB',
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": lang === 'el' ? 'Αρχική' : 'Home', "item": `${SITE}${localizedPath('/', lang)}` },
    { "@type": "ListItem", "position": 2, "name": "Portfolio", "item": `${SITE}${localizedPath('/portfolio', lang)}` },
  ],
};
---

<PageLayout
  title={t('meta.title')}
  description={t('meta.description')}
  image="/images/portfolio/editorial-bride-sunset.jpg"
  transparentHeader={true}
  additionalSchema={[collectionSchema, breadcrumbSchema]}
>
  <PortfolioPage />
</PageLayout>
