---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import BlogWeddingBeauticianPage from '../../../components/pages/BlogWeddingBeauticianPage.astro';
import enDict from '../../../i18n/en/blog';
import elDict from '../../../i18n/el/blog';
import { isLocale, useTranslations, type Locale } from '../../../i18n/utils';

const lang: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'en';
const t = useTranslations({ en: enDict, el: elDict }, lang);
---

<BlogLayout
  title={t('weddingBeautician.meta.title')}
  description={t('weddingBeautician.meta.description')}
  date={t('weddingBeautician.date')}
  category={t('weddingBeautician.category')}
  image={t('weddingBeautician.image')}
>
  <BlogWeddingBeauticianPage />
</BlogLayout>
