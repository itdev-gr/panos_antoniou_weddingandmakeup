---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import BlogBestWeddingMakeupServicesPage from '../../../components/pages/BlogBestWeddingMakeupServicesPage.astro';
import enDict from '../../../i18n/en/blog';
import elDict from '../../../i18n/el/blog';
import { isLocale, useTranslations, type Locale } from '../../../i18n/utils';

const lang: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'en';
const t = useTranslations({ en: enDict, el: elDict }, lang);
---

<BlogLayout
  title={t('bestWeddingMakeupServices.meta.title')}
  description={t('bestWeddingMakeupServices.meta.description')}
  date={t('bestWeddingMakeupServices.date')}
  category={t('bestWeddingMakeupServices.category')}
  image={t('bestWeddingMakeupServices.image')}
>
  <BlogBestWeddingMakeupServicesPage />
</BlogLayout>
