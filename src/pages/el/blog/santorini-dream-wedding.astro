---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import BlogSantoriniDreamWeddingPage from '../../../components/pages/BlogSantoriniDreamWeddingPage.astro';
import enDict from '../../../i18n/en/blog';
import elDict from '../../../i18n/el/blog';
import { isLocale, useTranslations, type Locale } from '../../../i18n/utils';

const lang: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'en';
const t = useTranslations({ en: enDict, el: elDict }, lang);
---

<BlogLayout
  title={t('santoriniDreamWedding.meta.title')}
  description={t('santoriniDreamWedding.meta.description')}
  date={t('santoriniDreamWedding.date')}
  category={t('santoriniDreamWedding.category')}
  image={t('santoriniDreamWedding.image')}
>
  <BlogSantoriniDreamWeddingPage />
</BlogLayout>
