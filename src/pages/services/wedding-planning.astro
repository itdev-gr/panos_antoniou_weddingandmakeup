---
import PageLayout from '../../layouts/PageLayout.astro';
import CTABanner from '../../components/home/CTABanner.astro';
import { planningServices, sameSexWeddingPackages } from '../../data/services';
---

<PageLayout
  title="Luxury Wedding Planner & Proposal Designer in Santorini | Panos Antoniou Weddings"
  description="Bespoke wedding planning, elopements, and luxury proposals in Santorini. We design seamless, high-aesthetic events tailored to your unique story."
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] lg:min-h-[70vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/services/ceremony-caldera.jpg" alt="Luxury wedding ceremony with caldera view Santorini" class="w-full h-full object-cover object-top" />
      <div class="absolute inset-0 bg-gradient-to-b from-near-black/70 via-near-black/50 to-near-black/70"></div>
    </div>
    <div class="container-content px-6 lg:px-12 text-center relative z-10">
      <h1 class="text-display-sm md:text-display lg:text-display-lg font-serif italic text-white leading-tight mb-6" data-reveal>
        Luxury Wedding Planner &amp; Proposal Designer in Santorini
      </h1>
      <p class="text-sm md:text-base font-sans tracking-widest-plus uppercase text-white/60" data-reveal>
        Panos Antoniou Weddings
      </p>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="bg-white py-20 lg:py-28 px-6 lg:px-12">
    <div class="container-content max-w-narrow mx-auto text-center" data-reveal>
      <div class="flex items-center justify-center gap-3 mb-10">
        <div class="w-10 h-px bg-gold"></div>
        <div class="w-1.5 h-1.5 rounded-full bg-gold"></div>
        <div class="w-10 h-px bg-gold"></div>
      </div>
      <p class="text-base md:text-lg font-serif text-grey leading-relaxed">
        At Panos Antoniou Weddings, we don't just organize events; we design memories. Our approach is deeply aesthetic, treating every wedding as a unique piece of art. With 26 years of experience in the beauty and wedding industry, we have the vision to synchronize every detail — from your bridal look to the floral arrangements — into one seamless, high-end experience.
      </p>
    </div>
  </section>

  <!-- Planning Services -->
  <section class="bg-off-white py-20 lg:py-28 px-6 lg:px-12">
    <div class="container-content max-w-narrow mx-auto">

      <!-- Category A: Full Wedding Planning -->
      <div class="mb-20" data-reveal>
        <div class="text-center mb-10">
          <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
            Category A
          </p>
          <h2 class="text-display-sm font-serif italic text-charcoal mb-4">
            Full Wedding Planning &amp; Design
          </h2>
          <p class="text-sm text-grey leading-relaxed max-w-lg mx-auto">
            A comprehensive service for couples who want every detail handled with precision. From venue scouting to vendor management and on-site coordination.
          </p>
        </div>
        <div class="space-y-0">
          {planningServices.fullPlanning.map((service, i) => (
            <div class="flex items-center justify-between py-5 border-b border-gold/20" style={`transition-delay: ${i * 80}ms`}>
              <span class="text-base md:text-lg font-serif text-charcoal">{service.name}</span>
              <span class="text-sm font-sans font-medium text-forest-green ml-4 whitespace-nowrap">Starting from {service.price}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Category B: Elopements -->
      <div class="mb-20" data-reveal>
        <div class="text-center mb-10">
          <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
            Category B
          </p>
          <h2 class="text-display-sm font-serif italic text-charcoal mb-4">
            Santorini Elopements
          </h2>
          <p class="text-sm text-grey leading-relaxed max-w-lg mx-auto">
            For those seeking a private, romantic ceremony against the backdrop of the Aegean Sea. We curate the most exclusive spots on the island for your &lsquo;I Do.&rsquo;
          </p>
        </div>
        <div class="space-y-0">
          {planningServices.elopements.map((service, i) => (
            <div class="flex items-center justify-between py-5 border-b border-gold/20" style={`transition-delay: ${i * 80}ms`}>
              <span class="text-base md:text-lg font-serif text-charcoal">{service.name}</span>
              <span class="text-sm font-sans font-medium text-forest-green ml-4 whitespace-nowrap">Starting from {service.price}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Category C: Proposals & Vow Renewals -->
      <div class="mb-20" data-reveal>
        <div class="text-center mb-10">
          <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
            Category C
          </p>
          <h2 class="text-display-sm font-serif italic text-charcoal mb-4">
            Luxury Proposals &amp; Vow Renewals
          </h2>
          <p class="text-sm text-grey leading-relaxed max-w-lg mx-auto">
            The ultimate setting for your most important questions. We design breathtaking proposal scenes and intimate vow renewals.
          </p>
        </div>
        <div class="space-y-0">
          {planningServices.proposals.map((service, i) => (
            <div class="flex items-center justify-between py-5 border-b border-gold/20" style={`transition-delay: ${i * 80}ms`}>
              <span class="text-base md:text-lg font-serif text-charcoal">{service.name}</span>
              <span class="text-sm font-sans font-medium text-forest-green ml-4 whitespace-nowrap">Starting from {service.price}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Category D: Same Sex Wedding -->
      <div id="same-sex-wedding" data-reveal>
        <div class="text-center mb-10">
          <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
            Category D
          </p>
          <h2 class="text-display-sm font-serif italic text-charcoal mb-4">
            Same Sex Wedding
          </h2>
          <p class="text-sm text-grey leading-relaxed max-w-lg mx-auto">
            Coordinated beauty and grooming experiences designed around two brides or two grooms &mdash; synchronized aesthetics, twin styling, and a dedicated team of artists.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {sameSexWeddingPackages.map((pkg, i) => (
            <div
              id={pkg.id}
              class="bg-white border border-gold/20 p-8 lg:p-10 hover:border-gold/50 transition-colors duration-300 flex flex-col scroll-mt-28"
              style={`transition-delay: ${i * 100}ms`}
            >
              <h3 class="text-xl font-serif italic text-charcoal mb-3">{pkg.name}</h3>
              <p class="text-lg font-sans font-medium text-forest-green mb-5">Starting from {pkg.price}</p>
              <div class="w-8 h-px bg-gold/40 mb-5"></div>
              {pkg.description && (
                <p class="text-sm text-grey leading-relaxed mb-5 italic">{pkg.description}</p>
              )}
              {pkg.details && (
                <ul class="space-y-2.5 text-sm text-grey/90 mb-5">
                  {pkg.details.map((d) => (
                    <li class="flex items-start justify-between gap-3">
                      <span class="flex items-start gap-3">
                        <span class="mt-2 w-1 h-1 rounded-full bg-gold/60 flex-shrink-0"></span>
                        <span>{d.label}</span>
                      </span>
                      <span class="text-gold/90 font-sans whitespace-nowrap">{d.price}</span>
                    </li>
                  ))}
                </ul>
              )}
              {pkg.features && (
                <ul class="space-y-1.5 text-sm text-grey/80 mb-5">
                  {pkg.features.map((f) => (
                    <li class="flex items-start gap-3">
                      <span class="mt-2 w-1 h-1 rounded-full bg-gold/40 flex-shrink-0"></span>
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>
              )}
              {pkg.note && (
                <p class="mt-auto text-xs text-grey/70 italic">{pkg.note}</p>
              )}
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- The Panos Antoniou Advantage -->
  <section class="bg-white py-20 lg:py-28 px-6 lg:px-12">
    <div class="container-content">
      <div class="text-center mb-14" data-reveal>
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
          Why Choose Us
        </p>
        <h2 class="text-display-sm md:text-display font-serif italic text-charcoal">
          The Panos Antoniou Advantage
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Local Santorini Experts -->
        <div class="text-center" data-reveal>
          <div class="w-12 h-12 rounded-full bg-off-white border border-gold/30 flex items-center justify-center mx-auto mb-5">
            <svg class="w-6 h-6 text-charcoal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 class="text-base font-serif italic text-charcoal mb-3">Local Santorini Experts</h3>
          <p class="text-sm text-grey leading-relaxed">
            We have direct access to the island's premier venues and elite local vendors, ensuring you get the best of Santorini.
          </p>
        </div>

        <!-- Aesthetic Synchronization -->
        <div class="text-center" data-reveal style="transition-delay: 100ms">
          <div class="w-12 h-12 rounded-full bg-off-white border border-gold/30 flex items-center justify-center mx-auto mb-5">
            <svg class="w-6 h-6 text-charcoal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-base font-serif italic text-charcoal mb-3">Aesthetic Synchronization</h3>
          <p class="text-sm text-grey leading-relaxed">
            We ensure your personal style and the event's design are perfectly aligned.
          </p>
        </div>

        <!-- Stress-Free Coordination -->
        <div class="text-center md:col-span-1" data-reveal style="transition-delay: 200ms">
          <div class="w-12 h-12 rounded-full bg-off-white border border-gold/30 flex items-center justify-center mx-auto mb-5">
            <svg class="w-6 h-6 text-charcoal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-base font-serif italic text-charcoal mb-3">Stress-Free Coordination</h3>
          <p class="text-sm text-grey leading-relaxed">
            Our team manages the logistics, so you can focus on the magic of your celebration.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title="Start Planning Your Santorini Story"
    buttonText="Contact Us"
    buttonHref="/contact"
  />
</PageLayout>
