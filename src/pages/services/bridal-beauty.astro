---
import PageLayout from '../../layouts/PageLayout.astro';
import CTABanner from '../../components/home/CTABanner.astro';
import { signatureServices, luxuryPackages, bridesmaidServices, eventServices } from '../../data/services';
---

<PageLayout
  title="The Best Bridal Makeup and Hair in Santorini | Panos Antoniou Weddings"
  description="High-end bridal makeup and hair services in Santorini. Explore our luxury beauty packages and visit our exclusive Bridal Lounge in Pyrgos. Book your trial."
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] lg:min-h-[70vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/services/bridal-beauty-hero.jpg" alt="Panos Antoniou applying bridal makeup in Santorini" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-gradient-to-b from-near-black/70 via-near-black/50 to-near-black/70"></div>
    </div>
    <div class="container-content px-6 lg:px-12 text-center relative z-10">
      <h1 class="text-display-sm md:text-display lg:text-display-lg font-serif italic text-white leading-tight mb-6" data-reveal>
        The Best Bridal Makeup and Hair in Santorini
      </h1>
      <p class="text-sm md:text-base font-sans tracking-widest-plus uppercase text-white/60" data-reveal>
        Panos Antoniou Weddings
      </p>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="bg-white py-20 lg:py-28 px-6 lg:px-12">
    <div class="container-content max-w-narrow mx-auto text-center" data-reveal>
      <!-- Gold Divider -->
      <div class="flex items-center justify-center gap-3 mb-10">
        <div class="w-10 h-px bg-gold"></div>
        <div class="w-1.5 h-1.5 rounded-full bg-gold"></div>
        <div class="w-10 h-px bg-gold"></div>
      </div>
      <p class="text-base md:text-lg font-serif text-grey leading-relaxed">
        With 26 years of experience in high-end editorials and luxury weddings, Panos Antoniou provides elite beauty services designed to reveal your most radiant self. Using a curated kit of world-class brands (Chanel, Armani, Shiseido, MAC, and K-Beauty innovation), we ensure a flawless, long-lasting editorial finish that withstands the Santorini elements.
      </p>
    </div>
  </section>

  <!-- Signature Services -->
  <section class="bg-off-white py-20 lg:py-28 px-6 lg:px-12">
    <div class="container-content max-w-narrow mx-auto">
      <div class="text-center mb-14" data-reveal>
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
          Signature Services
        </p>
        <h2 class="text-display-sm md:text-display font-serif italic text-charcoal">
          Bridal Beauty Services
        </h2>
      </div>

      <div class="space-y-0" data-reveal>
        {signatureServices.map((service, i) => (
          <div class="border-b border-gold/20" style={`transition-delay: ${i * 80}ms`}>
            <div class="flex items-center justify-between py-5">
              <span class="text-base md:text-lg font-serif text-charcoal">{service.name}</span>
              <span class="text-sm font-sans font-medium text-gold ml-4 whitespace-nowrap">
                Starting from {service.price}{service.priceNote ? '*' : ''}
              </span>
            </div>
            {service.includes && (
              <ul class="pb-5 -mt-1 space-y-1.5 text-sm text-grey/90 leading-relaxed">
                {service.includes.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-2 w-1 h-1 rounded-full bg-gold/60 flex-shrink-0"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
      {signatureServices.some((s) => s.priceNote) && (
        <p class="mt-8 text-xs text-grey/70 text-center leading-relaxed italic" data-reveal>
          {`* ${signatureServices.find((s) => s.priceNote)?.priceNote ?? ''}`}
        </p>
      )}
    </div>
  </section>

  <!-- Bridesmaids & Guests -->
  <section class="bg-white py-20 lg:py-28 px-6 lg:px-12">
    <div class="container-content max-w-narrow mx-auto">
      <div class="text-center mb-14" data-reveal>
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
          For Your Loved Ones
        </p>
        <h2 class="text-display-sm md:text-display font-serif italic text-charcoal">
          Bridesmaids &amp; Guests
        </h2>
      </div>

      <div class="space-y-0" data-reveal>
        {bridesmaidServices.map((service, i) => (
          <div class="flex items-center justify-between py-5 border-b border-gold/20" style={`transition-delay: ${i * 80}ms`}>
            <span class="text-base md:text-lg font-serif text-charcoal">{service.name}</span>
            <span class="text-sm font-sans font-medium text-gold ml-4 whitespace-nowrap">Starting from {service.price}</span>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center space-y-2" data-reveal>
        <p class="text-sm text-grey/80 leading-relaxed italic">
          Bespoke packages and exclusive rates are available for group bookings.
        </p>
        <p class="text-sm text-grey/80 leading-relaxed italic">
          Group packages available for up to 20 people.
        </p>
      </div>
    </div>
  </section>

  <!-- Event Make-up and Hair -->
  <section class="bg-off-white py-20 lg:py-28 px-6 lg:px-12">
    <div class="container-content max-w-narrow mx-auto">
      <div class="text-center mb-14" data-reveal>
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
          Beyond the Wedding
        </p>
        <h2 class="text-display-sm md:text-display font-serif italic text-charcoal">
          Event Make-up and Hair
        </h2>
      </div>

      <div class="space-y-0" data-reveal>
        {eventServices.map((service, i) => (
          <div class="flex items-center justify-between py-5 border-b border-gold/20" style={`transition-delay: ${i * 80}ms`}>
            <span class="text-base md:text-lg font-serif text-charcoal">{service.name}</span>
            <span class="text-sm font-sans font-medium text-gold ml-4 whitespace-nowrap">Starting from {service.price}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Luxury Packages -->
  <section class="bg-white py-20 lg:py-28 px-6 lg:px-12">
    <div class="container-content">
      <div class="text-center mb-14" data-reveal>
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
          Curated Experiences
        </p>
        <h2 class="text-display-sm md:text-display font-serif italic text-charcoal">
          Luxury Packages
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {luxuryPackages.map((pkg, i) => (
          <div
            class="border border-gold/20 p-8 lg:p-10 text-center hover:border-gold/50 transition-colors duration-300"
            data-reveal
            style={`transition-delay: ${i * 100}ms`}
          >
            <h3 class="text-xl font-serif italic text-charcoal mb-4">{pkg.name}</h3>
            <p class="text-lg font-sans font-medium text-gold mb-6">Starting from {pkg.price}</p>
            <div class="w-8 h-px bg-gold/40 mx-auto mb-6"></div>
            <p class="text-sm text-grey leading-relaxed">{pkg.includes}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Booking Terms & Travel -->
  <section class="bg-off-white py-20 lg:py-28 px-6 lg:px-12">
    <div class="container-content">
      <div class="text-center mb-14" data-reveal>
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
          Good to Know
        </p>
        <h2 class="text-display-sm md:text-display font-serif italic text-charcoal">
          Booking &amp; Travel
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
        <!-- Location -->
        <div class="text-center" data-reveal>
          <div class="w-12 h-12 rounded-full bg-white border border-gold/30 flex items-center justify-center mx-auto mb-5">
            <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 class="text-base font-serif italic text-charcoal mb-3">Location</h3>
          <p class="text-sm text-grey leading-relaxed">
            Visit our exclusive Bridal Lounge in Pyrgos Village, Santorini, or we can travel to your location worldwide.
          </p>
        </div>

        <!-- Retainer -->
        <div class="text-center" data-reveal style="transition-delay: 100ms">
          <div class="w-12 h-12 rounded-full bg-white border border-gold/30 flex items-center justify-center mx-auto mb-5">
            <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-base font-serif italic text-charcoal mb-3">Retainer</h3>
          <p class="text-sm text-grey leading-relaxed">
            A non-refundable retainer (30% for Santorini / 50% for outside) is required to secure your date.
          </p>
        </div>

        <!-- Travel Fees -->
        <div class="text-center md:col-span-2 lg:col-span-1" data-reveal style="transition-delay: 200ms">
          <div class="w-12 h-12 rounded-full bg-white border border-gold/30 flex items-center justify-center mx-auto mb-5">
            <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
            </svg>
          </div>
          <h3 class="text-base font-serif italic text-charcoal mb-3">Travel Fees</h3>
          <p class="text-sm text-grey leading-relaxed">
            Starting from &euro;150&ndash;&euro;450 within Greece and &euro;300&ndash;&euro;1,100 for international destinations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title="Book the Best Weddings Makeup and Hair Experience"
    buttonText="Book Your Date"
    buttonHref="/contact"
  />
</PageLayout>
