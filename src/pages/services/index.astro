---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import CTABanner from '../../components/home/CTABanner.astro';
import PlaceholderImage from '../../components/ui/PlaceholderImage.astro';
import { services } from '../../data/services';
---

<PageLayout
  title="Services — Panos Antoniou | Wedding Makeup & Hair"
  description="Explore our luxury bridal beauty services: bridal makeup & hair, bridesmaids, photo shoot styling, and professional training classes."
  transparentHeader={true}
>
  <!-- Cinematic Hero -->
  <section class="relative min-h-[50vh] lg:min-h-[60vh] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/services/bridal-makeup.jpg" alt="" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-gradient-to-b from-brown-dark/30 via-brown-dark/50 to-brown-dark/80"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-brown-dark/60 via-transparent to-transparent"></div>
    </div>

    <div class="relative z-10 container-content px-6 lg:px-12 flex items-end pb-16 lg:pb-20 min-h-[50vh] lg:min-h-[60vh]">
      <div class="max-w-xl">
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-cream/50 mb-4" data-reveal>
          What We Offer
        </p>
        <h1 class="text-display-sm md:text-display lg:text-display-lg font-serif italic text-cream leading-tight mb-4" data-reveal>
          Our Services
        </h1>
        <div class="w-12 h-px bg-gold-muted/60 mb-5" data-reveal></div>
        <p class="text-base text-cream/60 leading-relaxed max-w-md" data-reveal>
          Every service is designed around you — your vision, your style, your unforgettable day.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="relative section-padding bg-cream">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-muted/40 to-transparent"></div>

    <div class="container-content">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        {services.map((service, i) => (
          <a
            href={service.slug}
            class="group block bg-sand/30 rounded-sm overflow-hidden hover:shadow-lg transition-shadow duration-500"
            data-reveal
            style={`transition-delay: ${i * 100}ms`}
          >
            <div class="aspect-[16/10] overflow-hidden relative">
              <img src={service.image} alt={service.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-brown-dark/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </div>
            <div class="p-8">
              <h3 class="text-xl font-serif italic text-brown-dark mb-3 group-hover:text-accent transition-colors duration-300">
                {service.title}
              </h3>
              <p class="text-sm text-accent-light leading-relaxed mb-4">
                {service.description}
              </p>
              <ul class="space-y-2 mb-6">
                {service.features.map((f) => (
                  <li class="flex items-center gap-2 text-sm text-brown/70">
                    <div class="w-1 h-1 rounded-full bg-gold-muted flex-shrink-0"></div>
                    {f}
                  </li>
                ))}
              </ul>
              <span class="inline-flex items-center gap-2 text-xs font-sans font-medium tracking-widest uppercase text-accent group-hover:gap-3 transition-all duration-300">
                Learn More
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Reassurance Strip -->
  <section class="bg-sand/50 border-t border-sand-dark/50">
    <div class="container-content px-6 lg:px-12 py-12 lg:py-16">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 lg:gap-12 text-center">
        <div data-reveal>
          <div class="w-10 h-10 rounded-full bg-cream border border-sand-dark flex items-center justify-center mx-auto mb-4">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
          </div>
          <p class="text-sm font-serif italic text-brown-dark mb-1">Personalized Approach</p>
          <p class="text-xs text-accent-light/60">Tailored to your unique vision</p>
        </div>
        <div data-reveal style="transition-delay: 100ms">
          <div class="w-10 h-10 rounded-full bg-cream border border-sand-dark flex items-center justify-center mx-auto mb-4">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
            </svg>
          </div>
          <p class="text-sm font-serif italic text-brown-dark mb-1">Premium Products</p>
          <p class="text-xs text-accent-light/60">Only the finest brands & formulas</p>
        </div>
        <div data-reveal style="transition-delay: 200ms">
          <div class="w-10 h-10 rounded-full bg-cream border border-sand-dark flex items-center justify-center mx-auto mb-4">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <p class="text-sm font-serif italic text-brown-dark mb-1">Available Worldwide</p>
          <p class="text-xs text-accent-light/60">Destination weddings everywhere</p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner />
</PageLayout>
