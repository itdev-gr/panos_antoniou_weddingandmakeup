---
import PageLayout from '../../layouts/PageLayout.astro';
import CTABanner from '../../components/home/CTABanner.astro';
---

<PageLayout
  title="Wedding Services Santorini | Panos Antoniou Weddings"
  description="Explore our luxury wedding services in Santorini — bridal makeup and hair, wedding planning, and bespoke combined experiences."
  transparentHeader={true}
>
  <!-- Hero -->
  <section class="relative py-28 lg:py-36 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/scenery/santorini-bell-tower.jpg" alt="" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-gradient-to-b from-near-black/70 via-near-black/60 to-near-black/80"></div>
    </div>
    <div class="relative z-10 container-content text-center px-6">
      <h2 class="text-display-sm md:text-display lg:text-display-lg font-serif italic text-white mb-4" data-reveal>
        Our Services
      </h2>
      <div class="flex items-center justify-center gap-3 mb-6" data-reveal>
        <div class="w-10 h-px bg-gold"></div>
        <div class="w-1 h-1 rounded-full bg-gold"></div>
        <div class="w-10 h-px bg-gold"></div>
      </div>
      <p class="text-base text-white/60 max-w-md mx-auto leading-relaxed" data-reveal>
        Two pillars of your perfect wedding experience.
      </p>
    </div>
  </section>

  <!-- Service Cards -->
  <section class="section-padding bg-white">
    <div class="container-content">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 mb-20 lg:mb-24">

        <!-- Card 1: Bridal Makeup & Hair -->
        <a href="/services/bridal-beauty" class="group block bg-off-white rounded-sm overflow-hidden hover:shadow-lg transition-shadow duration-500" data-reveal>
          <div class="aspect-[3/2] overflow-hidden">
            <img
              src="/images/services/bridal-closeup.jpg"
              alt="Bridal Makeup and Hair"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <div class="p-8">
            <h3 class="text-xl font-serif italic text-charcoal mb-3 group-hover:text-forest-green transition-colors duration-300">
              Bridal Makeup &amp; Hair
            </h3>
            <p class="text-sm text-grey leading-relaxed mb-4">
              High-end beauty services signed by Panos Antoniou Wedding Makeup and Hair.
            </p>
            <p class="text-sm font-sans font-medium text-gold mb-6">Starting from &euro;560</p>
            <span class="inline-flex items-center gap-2 text-xs font-sans font-medium tracking-widest uppercase text-forest-green group-hover:gap-3 transition-all duration-300">
              Learn More
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>

        <!-- Card 2: Wedding Planning & Design -->
        <a href="/services/wedding-planning" class="group block bg-off-white rounded-sm overflow-hidden hover:shadow-lg transition-shadow duration-500" data-reveal style="transition-delay: 100ms">
          <div class="aspect-[3/2] overflow-hidden">
            <img
              src="/images/services/ceremony-caldera.jpg"
              alt="Wedding Planning and Design"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <div class="p-8">
            <h3 class="text-xl font-serif italic text-charcoal mb-3 group-hover:text-forest-green transition-colors duration-300">
              Wedding Planning &amp; Design
            </h3>
            <p class="text-sm text-grey leading-relaxed mb-4">
              From concept to execution, we design your wedding with precision and style.
            </p>
            <p class="text-sm font-sans font-medium text-gold mb-6">Starting from &euro;1,200</p>
            <span class="inline-flex items-center gap-2 text-xs font-sans font-medium tracking-widest uppercase text-forest-green group-hover:gap-3 transition-all duration-300">
              Learn More
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>

      </div>

      <!-- Pricelist Download -->
      <div class="border-t border-b border-gold/20 py-12 lg:py-14 mb-20 lg:mb-24 text-center" data-reveal>
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-3">
          Complete Pricelist
        </p>
        <h3 class="text-display-sm font-serif italic text-charcoal mb-4">
          Download Our Brochure
        </h3>
        <p class="text-sm text-grey leading-relaxed mb-7 max-w-md mx-auto">
          A 15-page guide with every service, package, and inclusion at a glance.
        </p>
        <a
          href="/brochure/panos-antoniou-pricelist.pdf"
          download
          class="inline-flex items-center gap-3 px-9 py-4 bg-forest-green text-white text-xs font-sans font-medium tracking-[0.12em] uppercase hover:bg-green-light transition-all duration-300"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Download Pricelist (PDF)
        </a>
      </div>

      <!-- Bridal Beauty: detail cards -->
      <div class="text-center mb-14" data-reveal>
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-gold mb-4">
          Bridal Beauty
        </p>
        <h2 class="text-display-sm md:text-display font-serif italic text-charcoal">
          Services in Detail
        </h2>
      </div>

      <div class="flex flex-wrap justify-center gap-8 lg:gap-12 [&>*]:w-full md:[&>*]:w-[calc(50%-1rem)] lg:[&>*]:w-[calc(50%-1.5rem)]">

        <!-- Card: Full Bridal Beauty -->
        <a href="/services/bridal-beauty#full-bridal-beauty" class="group block bg-off-white rounded-sm overflow-hidden hover:shadow-lg transition-shadow duration-500" data-reveal>
          <div class="aspect-[3/2] overflow-hidden">
            <img
              src="/images/services/bridal-makeup.jpg"
              alt="Full Bridal Beauty makeup and hair service"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <div class="p-8">
            <h3 class="text-xl font-serif italic text-charcoal mb-3 group-hover:text-forest-green transition-colors duration-300">
              Full Bridal Beauty
            </h3>
            <p class="text-sm text-grey leading-relaxed mb-4">
              The complete bridal beauty experience &mdash; makeup, hair, skin preparation, and signature finishing touches for your wedding day.
            </p>
            <p class="text-sm font-sans font-medium text-gold mb-6">Starting from &euro;560</p>
            <span class="inline-flex items-center gap-2 text-xs font-sans font-medium tracking-widest uppercase text-forest-green group-hover:gap-3 transition-all duration-300">
              Learn More
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>

        <!-- Card: Pre or Next-Day Styling -->
        <a href="/services/bridal-beauty#pre-or-next-day-styling" class="group block bg-off-white rounded-sm overflow-hidden hover:shadow-lg transition-shadow duration-500" data-reveal style="transition-delay: 100ms">
          <div class="aspect-[3/2] overflow-hidden">
            <img
              src="/images/services/natural-bridal.jpg"
              alt="Pre or Next-Day Styling for rehearsal and welcome events"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <div class="p-8">
            <h3 class="text-xl font-serif italic text-charcoal mb-3 group-hover:text-forest-green transition-colors duration-300">
              Pre or Next-Day Styling
            </h3>
            <p class="text-sm text-grey leading-relaxed mb-4">
              Polished styling for your rehearsal dinner, welcome events, or the day after your wedding.
            </p>
            <p class="text-sm font-sans font-medium text-gold mb-6">Starting from &euro;250</p>
            <span class="inline-flex items-center gap-2 text-xs font-sans font-medium tracking-widest uppercase text-forest-green group-hover:gap-3 transition-all duration-300">
              Learn More
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>

        <!-- Card: Bridal Party & Event Beauty -->
        <a href="/services/bridal-beauty#bridal-party-event-beauty" class="group block bg-off-white rounded-sm overflow-hidden hover:shadow-lg transition-shadow duration-500" data-reveal>
          <div class="aspect-[3/2] overflow-hidden">
            <img
              src="/images/services/natural-blonde-bride.jpg"
              alt="Bridal party and event beauty makeup and hair styling"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <div class="p-8">
            <h3 class="text-xl font-serif italic text-charcoal mb-3 group-hover:text-forest-green transition-colors duration-300">
              Bridal Party &amp; Event Beauty
            </h3>
            <p class="text-sm text-grey leading-relaxed mb-4">
              Editorial makeup and hair for your bridal party and guests, with group packages available for up to 20 people.
            </p>
            <p class="text-sm font-sans font-medium text-gold mb-2">Starting from &euro;200 | *&euro;160</p>
            <p class="text-xs text-grey/70 italic mb-6">*Exclusive rates available only when Bridal Hair &amp; Makeup services have been booked by the bride.</p>
            <span class="inline-flex items-center gap-2 text-xs font-sans font-medium tracking-widest uppercase text-forest-green group-hover:gap-3 transition-all duration-300">
              Learn More
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>

        <!-- Card: Double Bridal Glow -->
        <a href="/services/bridal-beauty#double-bridal-glow" class="group block bg-off-white rounded-sm overflow-hidden hover:shadow-lg transition-shadow duration-500" data-reveal style="transition-delay: 100ms">
          <div class="aspect-[3/2] overflow-hidden">
            <img
              src="/images/portfolio/luxury-brides-panos.jpg"
              alt="Double Bridal Glow coordinated beauty experience for two brides"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <div class="p-8">
            <h3 class="text-xl font-serif italic text-charcoal mb-3 group-hover:text-forest-green transition-colors duration-300">
              Double Bridal Glow
            </h3>
            <p class="text-sm text-grey leading-relaxed mb-4">
              A coordinated beauty experience for two brides, ensuring a harmonious and high-end aesthetic for your wedding gallery.
            </p>
            <p class="text-sm font-sans font-medium text-gold mb-6">Starting from &euro;1,000</p>
            <span class="inline-flex items-center gap-2 text-xs font-sans font-medium tracking-widest uppercase text-forest-green group-hover:gap-3 transition-all duration-300">
              Learn More
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>

        <!-- Card: Groomed & Polished -->
        <a href="/services/bridal-beauty#groomed-and-polished" class="group block bg-off-white rounded-sm overflow-hidden hover:shadow-lg transition-shadow duration-500" data-reveal>
          <div class="aspect-[3/2] overflow-hidden">
            <img
              src="/images/portfolio/couple-floral-arch.jpg"
              alt="Groomed and Polished coordinated grooming experience for two grooms"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <div class="p-8">
            <h3 class="text-xl font-serif italic text-charcoal mb-3 group-hover:text-forest-green transition-colors duration-300">
              Groomed &amp; Polished
            </h3>
            <p class="text-sm text-grey leading-relaxed mb-4">
              Expert grooming for the groom duo &mdash; tailored services for a sharp, sophisticated, and camera-ready look.
            </p>
            <p class="text-sm font-sans font-medium text-gold mb-6">Starting from &euro;300</p>
            <span class="inline-flex items-center gap-2 text-xs font-sans font-medium tracking-widest uppercase text-forest-green group-hover:gap-3 transition-all duration-300">
              Learn More
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>

      </div>

    </div>
  </section>

  <!-- Combined Experience -->
  <section class="py-16 lg:py-20 bg-off-white">
    <div class="container-content max-w-2xl text-center px-6">
      <p class="text-[10px] font-sans font-medium tracking-[0.2em] uppercase text-gold mb-4" data-reveal>
        The Complete Package
      </p>
      <p class="text-base text-grey leading-relaxed mb-8" data-reveal>
        Looking for the complete package? Our Combined Experience merges bridal beauty with wedding planning for a seamless, stress-free journey.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-9 py-4 bg-gold text-white text-xs font-sans font-medium tracking-[0.12em] uppercase hover:bg-gold-light transition-all duration-300"
        data-reveal
      >
        Get in Touch
      </a>
    </div>
  </section>

  <CTABanner
    title="Let's Create Something Beautiful"
    buttonText="Book a Consultation"
    buttonHref="/contact"
  />
</PageLayout>
