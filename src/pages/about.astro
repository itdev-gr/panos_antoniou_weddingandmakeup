---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
import CTABanner from '../components/home/CTABanner.astro';
import PlaceholderImage from '../components/ui/PlaceholderImage.astro';
---

<PageLayout
  title="About Panos Antoniou — Wedding Makeup & Hair Artist"
  description="Meet Panos Antoniou — over 26 years of experience in luxury bridal beauty. Based in Santorini, serving brides worldwide."
  transparentHeader={true}
>
  <!-- Cinematic Hero -->
  <section class="relative min-h-[50vh] lg:min-h-[60vh] overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/portfolio/santorini-bridal-looks-3.jpg" alt="" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-gradient-to-b from-brown-dark/30 via-brown-dark/50 to-brown-dark/80"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-brown-dark/60 via-transparent to-transparent"></div>
    </div>

    <div class="relative z-10 container-content px-6 lg:px-12 flex items-end pb-16 lg:pb-20 min-h-[50vh] lg:min-h-[60vh]">
      <div class="max-w-xl">
        <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-cream/50 mb-4" data-reveal>
          Our Story
        </p>
        <h1 class="text-display-sm md:text-display lg:text-display-lg font-serif italic text-cream leading-tight mb-4" data-reveal>
          About Panos<br />Antoniou
        </h1>
        <div class="w-12 h-px bg-gold-muted/60 mb-5" data-reveal></div>
        <p class="text-base text-cream/60 leading-relaxed max-w-md" data-reveal>
          26+ years of crafting unforgettable bridal beauty across the world's most beautiful destinations.
        </p>
      </div>
    </div>
  </section>

  <!-- Bio Section -->
  <section class="relative section-padding bg-cream">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-muted/40 to-transparent"></div>

    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <!-- Portrait -->
        <div class="relative" data-reveal>
          <div class="aspect-[4/5] rounded-sm overflow-hidden">
            <PlaceholderImage src="/images/about/panos-portrait.jpg" alt="Panos Antoniou" label="Panos Antoniou" />
          </div>
          <div class="absolute -bottom-4 -right-4 w-full h-full border border-gold-muted rounded-sm -z-10"></div>
        </div>

        <!-- Bio Text -->
        <div data-reveal style="transition-delay: 150ms">
          <h2 class="text-display-sm font-serif italic text-brown-dark mb-6">A Passion for Bridal Beauty</h2>
          <div class="w-12 h-px bg-gold-muted mb-8"></div>

          <div class="space-y-5 text-base text-accent-light leading-relaxed">
            <p>
              With over 26 years of professional experience, Panos Antoniou has established himself as one of the most respected bridal beauty artists in Greece and across the world. His career spans thousands of weddings, each one approached with the same dedication, creativity, and attention to detail as the first.
            </p>
            <p>
              Panos's work is defined by three principles: <em>discretion, precision, and a deep understanding of modern luxury</em>. He believes that every bride deserves to feel like the most beautiful version of herself — not just for the photographs, but for the feeling she carries throughout the day.
            </p>
            <p>
              Based in Santorini, Panos regularly serves brides across Mykonos, Athens, Zakynthos, Chalkida, Amsterdam, and beyond. His willingness to travel worldwide has made him a trusted partner for destination weddings in the most exclusive venues.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Studio Announcement -->
  <section class="relative section-padding bg-sand/50">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-muted/40 to-transparent"></div>

    <div class="container-content max-w-narrow text-center">
      <div data-reveal>
        <div class="inline-flex items-center gap-4 mb-6">
          <div class="w-8 h-px bg-gold-muted"></div>
          <p class="text-[10px] font-sans font-medium tracking-ultra-wide uppercase text-accent-light">Coming Soon</p>
          <div class="w-8 h-px bg-gold-muted"></div>
        </div>
        <h2 class="text-display-sm md:text-display font-serif italic text-brown-dark mb-6">
          New Studio & Bridal Lounge
        </h2>
        <div class="w-12 h-px bg-gold-muted mx-auto mb-6"></div>
        <p class="text-base text-accent-light leading-relaxed mb-4">
          We are excited to announce the development of our new Makeup & Hair Studio and Bridal Lounge in Pyrgos, Santorini. This dedicated space will offer an elevated experience for brides — from consultations and trial sessions to day-of preparations in a serene, luxury setting.
        </p>
        <p class="text-base text-accent-light leading-relaxed">
          Together with our collaborative wedding planning office operated with Ioannis, we are creating a complete bridal experience that brings every element of your wedding beauty under one roof.
        </p>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="py-24 bg-brown-dark">
    <div class="container-content max-w-narrow text-center px-6">
      <div class="text-5xl font-serif text-cream/10 leading-none mb-4">&ldquo;</div>
      <p class="text-xl md:text-2xl font-serif italic text-cream/80 leading-relaxed mb-6" data-reveal>
        My philosophy is simple: every bride should feel extraordinary. Not just beautiful — but confident, radiant, and authentically herself.
      </p>
      <div class="w-8 h-px bg-cream/20 mx-auto mb-4"></div>
      <p class="text-sm font-sans text-cream/40">Panos Antoniou</p>
    </div>
  </section>

  <!-- Reassurance Strip -->
  <section class="bg-sand/50 border-t border-sand-dark/50">
    <div class="container-content px-6 lg:px-12 py-12 lg:py-16">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 lg:gap-12 text-center">
        <div data-reveal>
          <div class="w-10 h-10 rounded-full bg-cream border border-sand-dark flex items-center justify-center mx-auto mb-4">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
            </svg>
          </div>
          <p class="text-sm font-serif italic text-brown-dark mb-1">26+ Years Experience</p>
          <p class="text-xs text-accent-light/60">Thousands of brides worldwide</p>
        </div>
        <div data-reveal style="transition-delay: 100ms">
          <div class="w-10 h-10 rounded-full bg-cream border border-sand-dark flex items-center justify-center mx-auto mb-4">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <p class="text-sm font-serif italic text-brown-dark mb-1">Destination Specialist</p>
          <p class="text-xs text-accent-light/60">Greece, Europe & beyond</p>
        </div>
        <div data-reveal style="transition-delay: 200ms">
          <div class="w-10 h-10 rounded-full bg-cream border border-sand-dark flex items-center justify-center mx-auto mb-4">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
            </svg>
          </div>
          <p class="text-sm font-serif italic text-brown-dark mb-1">Luxury Approach</p>
          <p class="text-xs text-accent-light/60">Premium products & techniques</p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    title="Let's Create Something Beautiful"
    description="Whether it's your wedding day or a special occasion, we'd love to be part of your story."
  />
</PageLayout>
