---
import PageLayout from '../layouts/PageLayout.astro';
import CTABanner from '../components/home/CTABanner.astro';
---

<PageLayout
  title="Panos Antoniou Weddings Makeup and Hair | Luxury Event Planning Santorini"
  description="Meet Panos Antoniou, the visionary behind Santorini's premier bridal beauty and wedding planning brand. 26 years of artistry dedicated to your special day."
  transparentHeader={true}
>
  <!-- Hero -->
  <section class="relative min-h-[55vh] lg:min-h-[65vh] flex items-center justify-center overflow-hidden bg-near-black">
    <div class="absolute inset-0 bg-gradient-to-b from-near-black via-charcoal/40 to-near-black"></div>
    <div class="relative z-10 text-center px-6 py-24 lg:py-32 max-w-3xl mx-auto">
      <h1 class="text-display-lg font-serif text-white mb-6" data-reveal>
        The Art of Bridal Perfection
      </h1>
      <p class="text-lg md:text-xl italic text-white/60 font-serif leading-relaxed" data-reveal>
        "Beauty is not created; it is revealed."
      </p>
    </div>
  </section>

  <!-- Portrait + Bio -->
  <section class="bg-white py-20 lg:py-28 px-6 lg:px-12">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <!-- Left: Portrait -->
        <div data-reveal>
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src="/images/about/panos-portrait.jpg"
              alt="Panos Antoniou wedding makeup artist Santorini"
              class="w-full h-full object-cover"
            />
          </div>
        </div>

        <!-- Right: Bio -->
        <div data-reveal>
          <h2 class="text-display-sm font-serif text-charcoal mb-6">The Visionary</h2>
          <div class="w-12 h-px bg-gold mb-8"></div>

          <div class="space-y-5 text-base text-grey leading-relaxed">
            <p>
              With over 26 years of presence in the world of beauty, Panos Antoniou does not simply provide services; he unveils the most authentic and radiant version of every woman. His journey began with high-stakes productions and premier collaborations — from the prestige of the Athens 2004 Olympic Games to his role as a Pro Artist for MAC Cosmetics — evolving into a lifelong passion for the ultimate bridal experience.
            </p>
            <p>
              In 2016, he founded Panos Antoniou Weddings Makeup and Hair, bringing a high-aesthetic approach to Santorini and throughout Greece. His extensive experience with international brides led to the 2026 debut of his first Bridal Lounge &amp; Makeup Studio in Santorini — an exclusive sanctuary dedicated to private bridal preparation and luxury editorial photoshooting experiences.
            </p>
            <p>
              Based in Santorini, the Panos Antoniou Weddings Makeup and Hair team is available to serve you worldwide, combining the artistry of <a href="/services/bridal-beauty" class="text-forest-green underline underline-offset-2 hover:text-green-light transition-colors">makeup</a> with the strategic precision of bespoke <a href="/services/wedding-planning" class="text-forest-green underline underline-offset-2 hover:text-green-light transition-colors">wedding planning</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Career Milestones -->
  <section class="bg-off-white py-20 lg:py-28 px-6 lg:px-12">
    <div class="container-content max-w-narrow">
      <div class="text-center mb-16" data-reveal>
        <h2 class="text-display-sm font-serif text-charcoal mb-4">Career Milestones</h2>
        <div class="w-12 h-px bg-gold mx-auto"></div>
      </div>

      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-6 lg:left-1/2 top-0 bottom-0 w-px bg-gold/30 -translate-x-1/2"></div>

        <!-- 2004 -->
        <div class="relative flex items-start mb-12 lg:mb-16" data-reveal>
          <div class="absolute left-6 lg:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-gold border-2 border-off-white z-10"></div>
          <div class="ml-14 lg:ml-0 lg:w-1/2 lg:pr-12 lg:text-right">
            <span class="text-sm font-sans font-medium tracking-widest text-gold uppercase">2004</span>
            <h3 class="text-lg font-serif text-charcoal mt-1">Athens Olympic Games</h3>
            <p class="text-sm text-grey mt-1">Pro Artist</p>
          </div>
        </div>

        <!-- 2006 -->
        <div class="relative flex items-start mb-12 lg:mb-16" data-reveal>
          <div class="absolute left-6 lg:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-gold border-2 border-off-white z-10"></div>
          <div class="ml-14 lg:ml-auto lg:w-1/2 lg:pl-12">
            <span class="text-sm font-sans font-medium tracking-widest text-gold uppercase">2006</span>
            <h3 class="text-lg font-serif text-charcoal mt-1">MAC Cosmetics</h3>
            <p class="text-sm text-grey mt-1">Pro Team Member</p>
          </div>
        </div>

        <!-- 2016 -->
        <div class="relative flex items-start mb-12 lg:mb-16" data-reveal>
          <div class="absolute left-6 lg:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-gold border-2 border-off-white z-10"></div>
          <div class="ml-14 lg:ml-0 lg:w-1/2 lg:pr-12 lg:text-right">
            <span class="text-sm font-sans font-medium tracking-widest text-gold uppercase">2016</span>
            <h3 class="text-lg font-serif text-charcoal mt-1">Founded Panos Antoniou Weddings Makeup and Hair</h3>
            <p class="text-sm text-grey mt-1">Santorini & throughout Greece</p>
          </div>
        </div>

        <!-- 2026 -->
        <div class="relative flex items-start" data-reveal>
          <div class="absolute left-6 lg:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-gold border-2 border-off-white z-10"></div>
          <div class="ml-14 lg:ml-auto lg:w-1/2 lg:pl-12">
            <span class="text-sm font-sans font-medium tracking-widest text-gold uppercase">2026</span>
            <h3 class="text-lg font-serif text-charcoal mt-1">The Bridal Lounge & Makeup Studio</h3>
            <p class="text-sm text-grey mt-1">Santorini</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title="Discover Our Services"
    buttonText="View Services"
    buttonHref="/services"
  />
</PageLayout>
