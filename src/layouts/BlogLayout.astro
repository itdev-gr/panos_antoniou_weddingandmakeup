---
import PageLayout from './PageLayout.astro';
import Button from '../components/ui/Button.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  image: string;
}

const { title, description, date, category, image } = Astro.props;
---

<PageLayout title={`${title} — Panos Antoniou Blog`} description={description} transparentHeader={true}>
  <!-- Hero -->
  <section class="relative min-h-[45vh] lg:min-h-[55vh] bg-gradient-to-b from-forest-green via-forest-green/95 to-green-light overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(184,151,106,0.1),transparent_70%)]"></div>

    <div class="relative z-10 container-content px-6 lg:px-12 flex items-end pb-16 lg:pb-20 min-h-[45vh] lg:min-h-[55vh]">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-[10px] font-sans font-medium tracking-widest uppercase text-white/70 bg-white/10 backdrop-blur-sm px-3 py-1 rounded-full">
            {category}
          </span>
          <span class="text-xs text-white/50">{date}</span>
        </div>
        <h1 class="text-display-sm md:text-display font-serif italic text-white leading-tight mb-4" data-reveal>
          {title}
        </h1>
        <div class="w-12 h-px bg-gold/60" data-reveal></div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <article class="relative section-padding bg-white">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>

    <div class="container-content max-w-narrow px-6 prose prose-lg prose-stone">
      <slot />
    </div>
  </article>

  <!-- Back to Blog -->
  <section class="pb-20 bg-white">
    <div class="container-content max-w-narrow px-6 text-center">
      <Button variant="outline" href="/blog">Back to Blog</Button>
    </div>
  </section>
</PageLayout>
